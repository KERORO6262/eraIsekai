; 職責：角色能力初始化與種族/職業文字轉換。
@INIT_CHARA_STATS, ARG
LOCAL:0 = ARG
LOCAL:1 = CFLAG:(LOCAL:0):CF_RACE
LOCAL:2 = CFLAG:(LOCAL:0):CF_JOB

; 級距：速度、暴擊、物攻、魔攻、特攻、物防、魔防
LOCAL:10 = 2
LOCAL:11 = 2
LOCAL:12 = 2
LOCAL:13 = 2
LOCAL:14 = 2
LOCAL:15 = 2
LOCAL:16 = 2

; 種族基礎
SELECTCASE LOCAL:1
    CASE RACE_HUMAN
        ; 均衡，維持預設
    CASE RACE_ELF
        LOCAL:10 = 3
        LOCAL:12 = 1
        LOCAL:13 = 4
        LOCAL:15 = 1
        LOCAL:16 = 3
    CASE RACE_HALFLING
        LOCAL:10 = 3
        LOCAL:11 = 3
        LOCAL:12 = 1
        LOCAL:13 = 1
        LOCAL:14 = 3
        LOCAL:16 = 3
    CASE RACE_DWARF
        LOCAL:10 = 1
        LOCAL:11 = 1
        LOCAL:12 = 3
        LOCAL:13 = 1
        LOCAL:14 = 2
        LOCAL:15 = 4
        LOCAL:16 = 3
    CASE RACE_ORC
        LOCAL:10 = 2
        LOCAL:11 = 3
        LOCAL:12 = 4
        LOCAL:13 = 1
        LOCAL:14 = 1
        LOCAL:15 = 3
        LOCAL:16 = 1
    CASE RACE_DRAGONEWT
        LOCAL:10 = 2
        LOCAL:11 = 2
        LOCAL:12 = 3
        LOCAL:13 = 2
        LOCAL:14 = 4
        LOCAL:15 = 4
        LOCAL:16 = 2
    CASE RACE_HARPY
        LOCAL:10 = 4
        LOCAL:11 = 4
        LOCAL:12 = 2
        LOCAL:13 = 2
        LOCAL:14 = 2
        LOCAL:15 = 1
        LOCAL:16 = 1
    CASE RACE_LAMIA
        LOCAL:10 = 2
        LOCAL:11 = 2
        LOCAL:12 = 2
        LOCAL:13 = 3
        LOCAL:14 = 4
        LOCAL:15 = 2
        LOCAL:16 = 3
    CASEELSE
        ; 未設定時回退人類
        CFLAG:(LOCAL:0):CF_RACE = RACE_HUMAN
ENDSELECT

; 職業加成
SELECTCASE LOCAL:2
    CASE JOB_PALADIN
        LOCAL:15 += 2
        LOCAL:16 += 1
        LOCAL:10 -= 1
    CASE JOB_MAGE
        LOCAL:13 += 2
        LOCAL:14 += 1
        LOCAL:12 -= 1
    CASE JOB_MERCHANT
        LOCAL:10 += 1
        LOCAL:11 += 1
        LOCAL:14 += 1
    CASE JOB_BLACKSMITH
        LOCAL:12 += 1
        LOCAL:15 += 2
        LOCAL:10 -= 1
    CASE JOB_HUNTER
        LOCAL:10 += 1
        LOCAL:11 += 2
        LOCAL:16 -= 1
    CASE JOB_WARRIOR
        LOCAL:12 += 2
        LOCAL:15 += 1
        LOCAL:13 -= 1
    CASE JOB_ASSASSIN
        LOCAL:10 += 2
        LOCAL:11 += 2
        LOCAL:15 -= 1
        LOCAL:16 -= 1
    CASE JOB_DIVINER
        LOCAL:13 += 1
        LOCAL:14 += 2
        LOCAL:15 -= 1
    CASEELSE
        CFLAG:(LOCAL:0):CF_JOB = JOB_WARRIOR
ENDSELECT

; Clamp 到 1~5
LOCAL:10 = LIMIT(LOCAL:10, 1, 5)
LOCAL:11 = LIMIT(LOCAL:11, 1, 5)
LOCAL:12 = LIMIT(LOCAL:12, 1, 5)
LOCAL:13 = LIMIT(LOCAL:13, 1, 5)
LOCAL:14 = LIMIT(LOCAL:14, 1, 5)
LOCAL:15 = LIMIT(LOCAL:15, 1, 5)
LOCAL:16 = LIMIT(LOCAL:16, 1, 5)

; 速度換算：1=10,2=15,3=20,4=25,5=35
BASE:(LOCAL:0):BTL_SPEED = 10
IF LOCAL:10 == 2
    BASE:(LOCAL:0):BTL_SPEED = 15
ELSEIF LOCAL:10 == 3
    BASE:(LOCAL:0):BTL_SPEED = 20
ELSEIF LOCAL:10 == 4
    BASE:(LOCAL:0):BTL_SPEED = 25
ELSEIF LOCAL:10 >= 5
    BASE:(LOCAL:0):BTL_SPEED = 35
ENDIF

; 暴擊換算：1=3,2=5,3=8,4=12,5=20
BASE:(LOCAL:0):BTL_CRIT = 3
IF LOCAL:11 == 2
    BASE:(LOCAL:0):BTL_CRIT = 5
ELSEIF LOCAL:11 == 3
    BASE:(LOCAL:0):BTL_CRIT = 8
ELSEIF LOCAL:11 == 4
    BASE:(LOCAL:0):BTL_CRIT = 12
ELSEIF LOCAL:11 >= 5
    BASE:(LOCAL:0):BTL_CRIT = 20
ENDIF

; 攻防換算：1=5,2=10,3=15,4=20,5=25
BASE:(LOCAL:0):BTL_PATK = LOCAL:12 * 5
BASE:(LOCAL:0):BTL_MATK = LOCAL:13 * 5
BASE:(LOCAL:0):BTL_SATK = LOCAL:14 * 5
BASE:(LOCAL:0):BTL_PDEF = LOCAL:15 * 5
BASE:(LOCAL:0):BTL_MDEF = LOCAL:16 * 5
RETURN

@GET_RACE_STR, ARG
LOCAL:0 = ARG
SELECTCASE LOCAL:0
    CASE RACE_HUMAN
        RESULTS:0 = "人類(1)"
    CASE RACE_ELF
        RESULTS:0 = "精靈(2)"
    CASE RACE_HALFLING
        RESULTS:0 = "半身人(3)"
    CASE RACE_DWARF
        RESULTS:0 = "矮人(4)"
    CASE RACE_ORC
        RESULTS:0 = "獸人(5)"
    CASE RACE_DRAGONEWT
        RESULTS:0 = "龍人(6)"
    CASE RACE_HARPY
        RESULTS:0 = "鳥人(7)"
    CASE RACE_LAMIA
        RESULTS:0 = "蛇人(8)"
    CASEELSE
        RESULTS:0 = "未設定"
ENDSELECT
RETURN

@GET_JOB_STR, ARG
LOCAL:0 = ARG
SELECTCASE LOCAL:0
    CASE JOB_PALADIN
        RESULTS:1 = "聖騎士(1)"
    CASE JOB_MAGE
        RESULTS:1 = "法師(2)"
    CASE JOB_MERCHANT
        RESULTS:1 = "商人(3)"
    CASE JOB_BLACKSMITH
        RESULTS:1 = "鐵匠(4)"
    CASE JOB_HUNTER
        RESULTS:1 = "獵人(5)"
    CASE JOB_WARRIOR
        RESULTS:1 = "戰士(6)"
    CASE JOB_ASSASSIN
        RESULTS:1 = "刺客(7)"
    CASE JOB_DIVINER
        RESULTS:1 = "占卜師(8)"
    CASEELSE
        RESULTS:1 = "未設定"
ENDSELECT
RETURN


@INIT_MASTER_STATS
; MASTER（Chara 0）戰鬥基礎能力初始化
IF MASTER != 0
    MASTER = 0
ENDIF
BASE:MASTER:BTL_MAXHP = 100
BASE:MASTER:BTL_HP = 100
BASE:MASTER:BTL_MAXEN = 10
BASE:MASTER:BTL_EN = 10
BASE:MASTER:BTL_PATK = 15
BASE:MASTER:BTL_MATK = 15
BASE:MASTER:BTL_PDEF = 5
BASE:MASTER:BTL_MDEF = 5
RETURN

@CHARA_EVENT_NIGHT
; 日末數值結算：入住 NPC 疲勞自然下降，過勞會降低心情
LOCAL:10 = FLAG:BASE_FAC_LV_ROOM
IF LOCAL:10 < 0
    LOCAL:10 = 0
ELSEIF LOCAL:10 > ROOM_OWNER_MAX
    LOCAL:10 = ROOM_OWNER_MAX
ENDIF

FOR LOCAL, 0, LOCAL:10
    IF ROOM_OWNER:LOCAL == -1
        CONTINUE
    ENDIF

    LOCAL:1 = ROOM_OWNER:LOCAL
    LOCAL:2 = CFLAG:(LOCAL:1):CF_FATIGUE
    LOCAL:3 = 8 + FLAG:BASE_FAC_LV_LOUNGE * 2
    LOCAL:2 -= LOCAL:3
    IF LOCAL:2 < 0
        LOCAL:2 = 0
    ENDIF
    CFLAG:(LOCAL:1):CF_FATIGUE = LOCAL:2

    IF LOCAL:2 >= 80
        CFLAG:(LOCAL:1):CF_MOOD -= 8
    ELSEIF LOCAL:2 >= 60
        CFLAG:(LOCAL:1):CF_MOOD -= 3
    ELSE
        CFLAG:(LOCAL:1):CF_MOOD += 1
    ENDIF

    IF CFLAG:(LOCAL:1):CF_MOOD < 0
        CFLAG:(LOCAL:1):CF_MOOD = 0
    ELSEIF CFLAG:(LOCAL:1):CF_MOOD > 100
        CFLAG:(LOCAL:1):CF_MOOD = 100
    ENDIF
NEXT
RETURN
