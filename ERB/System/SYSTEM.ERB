; 職責：系統啟動入口、全域初始化與標題畫面。
@EVENTFIRST
; ===== 系統啟動入口 =====
; 僅在新遊戲啟動時初始化，避免讀檔時覆蓋存檔數值
IF FLAG:SYS_INITIALIZED == 0
    CALL INIT_BASE_STATE
ENDIF
CALL TITLE_SCREEN
RETURN

@INIT_BASE_STATE
; ===== 全域初始化 =====
FLAG:SYS_INITIALIZED = 1

; 初始化玩家角色（0 號為 MASTER）
ADDCHARA 0
MASTER = 0

FLAG:BASE_DAY = 1
FLAG:DAY_PHASE = 1

; Core Loop 初始資源（可依平衡再調整）
FLAG:RES_MONEY = 1000
FLAG:RES_MATERIAL = 80
FLAG:RES_SUPPLY = 60

; 基地設施初始等級
FLAG:BASE_FAC_LV_TRAIN = 1
FLAG:BASE_FAC_LV_WORK = 1
FLAG:BASE_FAC_LV_LOUNGE = 1
FLAG:BASE_FAC_LV_ROOM = 1

CALL INIT_ROOM_OWNER
CALL INIT_WORK_QUEUE
CALL INIT_SKILL_DATA
CALL INIT_MASTER_STATS

; 當日流程保護旗標
TFLAG:MORNING_DONE = 0
TFLAG:RETURN_PHASE = 0
TFLAG:AUTO_TURNS_LEFT = 0

CFLAG:MASTER:CF_AI_W_DAMAGE = 50
CFLAG:MASTER:CF_AI_W_GUARD = 50
RETURN

@INIT_ROOM_OWNER
FOR LOCAL, 0, ROOM_OWNER_MAX - 1
    ROOM_OWNER:LOCAL = -1
NEXT
RETURN

@INIT_WORK_QUEUE
; 工坊生產佇列初始化
FOR LOCAL, 0, WORK_Q_MAX
    WORK_Q_TYPE:LOCAL = 0
    WORK_Q_REMAIN:LOCAL = 0
NEXT
RETURN

@INIT_SKILL_DATA
; ===== 技能配方資料初始化（四象元素） =====
; 先清空本期使用區間，避免重複初始化時殘留舊值
FOR LOCAL, 20000, 20010
    SKILL_REQ_PHYS:LOCAL = 0
    SKILL_REQ_MAG:LOCAL = 0
    SKILL_REQ_DEF:LOCAL = 0
    SKILL_REQ_SPEC:LOCAL = 0
NEXT

; 20001 重力斬擊：2 物理 + 1 魔法
SKILL_REQ_PHYS:20001 = 2
SKILL_REQ_MAG:20001 = 1

; 20002 絕對防禦：3 防禦
SKILL_REQ_DEF:20002 = 3

; 20003 治癒之風：1 魔法 + 1 防禦
SKILL_REQ_MAG:20003 = 1
SKILL_REQ_DEF:20003 = 1

; 20004 堅壁陣型：2 防禦
SKILL_REQ_DEF:20004 = 2
RETURN

@TITLE_SCREEN
$TITLE_TOP
DRAWLINE
PRINTL  ERA ISEKAI
PRINTL  養成 × 經營 × 抽牌戰鬥
DRAWLINE
PRINTL  [1] 開始遊戲
PRINTL  [0] 結束
PRINTL
PRINTFORML 請輸入選項：
INPUT RESULT

IF RESULT == 1
    CALL GAME_LOOP
    RETURN
ELSEIF RESULT == 0
    QUIT
ELSE
    PRINTL 請輸入 1 或 0。
    GOTO TITLE_TOP
ENDIF
