@EVENTFIRST
; ===== 系統啟動入口 =====
; 僅在新遊戲啟動時初始化，避免讀檔時覆蓋存檔數值
IF FLAG:SYS_INITIALIZED == 0
    CALL INIT_BASE_STATE
ENDIF
CALL TITLE_SCREEN
RETURN

@INIT_BASE_STATE
; ===== 全域初始化 =====
FLAG:SYS_INITIALIZED = 1

; 初始化玩家角色（0 號為 MASTER）
ADDCHARA 0
MASTER = 0

FLAG:BASE_DAY = 1
FLAG:DAY_PHASE = 1

; Core Loop 初始資源（可依平衡再調整）
FLAG:RES_MONEY = 1000
FLAG:RES_MATERIAL = 80
FLAG:RES_SUPPLY = 60

; 基地設施初始等級
FLAG:BASE_FAC_LV_TRAIN = 1
FLAG:BASE_FAC_LV_WORK = 1
FLAG:BASE_FAC_LV_LOUNGE = 1
FLAG:BASE_FAC_LV_ROOM = 1

CALL INIT_ROOM_OWNER
CALL INIT_WORK_QUEUE
CALL INIT_SKILL_DATA

; 當日流程保護旗標
TFLAG:MORNING_DONE = 0
TFLAG:RETURN_PHASE = 0
RETURN

@INIT_ROOM_OWNER
FOR LOCAL, 0, ROOM_OWNER_MAX - 1
    ROOM_OWNER:LOCAL = -1
NEXT
RETURN

@INIT_WORK_QUEUE
; 工坊生產佇列初始化
FOR LOCAL, 0, WORK_Q_MAX
    WORK_Q_TYPE:LOCAL = 0
    WORK_Q_REMAIN:LOCAL = 0
NEXT
RETURN

@INIT_SKILL_DATA
; ===== 技能配方資料初始化（四象元素） =====
; 先清空本期使用區間，避免重複初始化時殘留舊值
FOR LOCAL, 20000, 20010
    SKILL_REQ_PHYS:LOCAL = 0
    SKILL_REQ_MAG:LOCAL = 0
    SKILL_REQ_DEF:LOCAL = 0
    SKILL_REQ_SPEC:LOCAL = 0
NEXT

; 20001 重力斬擊：2 物理 + 1 魔法
SKILL_REQ_PHYS:20001 = 2
SKILL_REQ_MAG:20001 = 1

; 20002 絕對防禦：3 防禦
SKILL_REQ_DEF:20002 = 3
RETURN

@INIT_CHARA_STATS, ARG
LOCAL:0 = ARG
LOCAL:1 = CFLAG:(LOCAL:0):CF_RACE
LOCAL:2 = CFLAG:(LOCAL:0):CF_JOB

; 級距：速度、暴擊、物攻、魔攻、特攻、物防、魔防
LOCAL:10 = 2
LOCAL:11 = 2
LOCAL:12 = 2
LOCAL:13 = 2
LOCAL:14 = 2
LOCAL:15 = 2
LOCAL:16 = 2

; 種族基礎
SELECTCASE LOCAL:1
    CASE RACE_HUMAN
        ; 均衡，維持預設
    CASE RACE_ELF
        LOCAL:10 = 3
        LOCAL:12 = 1
        LOCAL:13 = 4
        LOCAL:15 = 1
        LOCAL:16 = 3
    CASE RACE_HALFLING
        LOCAL:10 = 3
        LOCAL:11 = 3
        LOCAL:12 = 1
        LOCAL:13 = 1
        LOCAL:14 = 3
        LOCAL:16 = 3
    CASE RACE_DWARF
        LOCAL:10 = 1
        LOCAL:11 = 1
        LOCAL:12 = 3
        LOCAL:13 = 1
        LOCAL:14 = 2
        LOCAL:15 = 4
        LOCAL:16 = 3
    CASE RACE_ORC
        LOCAL:10 = 2
        LOCAL:11 = 3
        LOCAL:12 = 4
        LOCAL:13 = 1
        LOCAL:14 = 1
        LOCAL:15 = 3
        LOCAL:16 = 1
    CASE RACE_DRAGONEWT
        LOCAL:10 = 2
        LOCAL:11 = 2
        LOCAL:12 = 3
        LOCAL:13 = 2
        LOCAL:14 = 4
        LOCAL:15 = 4
        LOCAL:16 = 2
    CASE RACE_HARPY
        LOCAL:10 = 4
        LOCAL:11 = 4
        LOCAL:12 = 2
        LOCAL:13 = 2
        LOCAL:14 = 2
        LOCAL:15 = 1
        LOCAL:16 = 1
    CASE RACE_LAMIA
        LOCAL:10 = 2
        LOCAL:11 = 2
        LOCAL:12 = 2
        LOCAL:13 = 3
        LOCAL:14 = 4
        LOCAL:15 = 2
        LOCAL:16 = 3
    CASEELSE
        ; 未設定時回退人類
        CFLAG:(LOCAL:0):CF_RACE = RACE_HUMAN
ENDSELECT

; 職業加成
SELECTCASE LOCAL:2
    CASE JOB_PALADIN
        LOCAL:15 += 2
        LOCAL:16 += 1
        LOCAL:10 -= 1
    CASE JOB_MAGE
        LOCAL:13 += 2
        LOCAL:14 += 1
        LOCAL:12 -= 1
    CASE JOB_MERCHANT
        LOCAL:10 += 1
        LOCAL:11 += 1
        LOCAL:14 += 1
    CASE JOB_BLACKSMITH
        LOCAL:12 += 1
        LOCAL:15 += 2
        LOCAL:10 -= 1
    CASE JOB_HUNTER
        LOCAL:10 += 1
        LOCAL:11 += 2
        LOCAL:16 -= 1
    CASE JOB_WARRIOR
        LOCAL:12 += 2
        LOCAL:15 += 1
        LOCAL:13 -= 1
    CASE JOB_ASSASSIN
        LOCAL:10 += 2
        LOCAL:11 += 2
        LOCAL:15 -= 1
        LOCAL:16 -= 1
    CASE JOB_DIVINER
        LOCAL:13 += 1
        LOCAL:14 += 2
        LOCAL:15 -= 1
    CASEELSE
        CFLAG:(LOCAL:0):CF_JOB = JOB_WARRIOR
ENDSELECT

; Clamp 到 1~5
LOCAL:10 = LIMIT(LOCAL:10, 1, 5)
LOCAL:11 = LIMIT(LOCAL:11, 1, 5)
LOCAL:12 = LIMIT(LOCAL:12, 1, 5)
LOCAL:13 = LIMIT(LOCAL:13, 1, 5)
LOCAL:14 = LIMIT(LOCAL:14, 1, 5)
LOCAL:15 = LIMIT(LOCAL:15, 1, 5)
LOCAL:16 = LIMIT(LOCAL:16, 1, 5)

; 速度換算：1=10,2=15,3=20,4=25,5=35
BASE:(LOCAL:0):BTL_SPEED = 10
IF LOCAL:10 == 2
    BASE:(LOCAL:0):BTL_SPEED = 15
ELSEIF LOCAL:10 == 3
    BASE:(LOCAL:0):BTL_SPEED = 20
ELSEIF LOCAL:10 == 4
    BASE:(LOCAL:0):BTL_SPEED = 25
ELSEIF LOCAL:10 >= 5
    BASE:(LOCAL:0):BTL_SPEED = 35
ENDIF

; 暴擊換算：1=3,2=5,3=8,4=12,5=20
BASE:(LOCAL:0):BTL_CRIT = 3
IF LOCAL:11 == 2
    BASE:(LOCAL:0):BTL_CRIT = 5
ELSEIF LOCAL:11 == 3
    BASE:(LOCAL:0):BTL_CRIT = 8
ELSEIF LOCAL:11 == 4
    BASE:(LOCAL:0):BTL_CRIT = 12
ELSEIF LOCAL:11 >= 5
    BASE:(LOCAL:0):BTL_CRIT = 20
ENDIF

; 攻防換算：1=5,2=10,3=15,4=20,5=25
BASE:(LOCAL:0):BTL_PATK = LOCAL:12 * 5
BASE:(LOCAL:0):BTL_MATK = LOCAL:13 * 5
BASE:(LOCAL:0):BTL_SATK = LOCAL:14 * 5
BASE:(LOCAL:0):BTL_PDEF = LOCAL:15 * 5
BASE:(LOCAL:0):BTL_MDEF = LOCAL:16 * 5
RETURN

@GET_RACE_STR, ARG
LOCAL:0 = ARG
SELECTCASE LOCAL:0
    CASE RACE_HUMAN
        RESULTS:0 = "人類(1)"
    CASE RACE_ELF
        RESULTS:0 = "精靈(2)"
    CASE RACE_HALFLING
        RESULTS:0 = "半身人(3)"
    CASE RACE_DWARF
        RESULTS:0 = "矮人(4)"
    CASE RACE_ORC
        RESULTS:0 = "獸人(5)"
    CASE RACE_DRAGONEWT
        RESULTS:0 = "龍人(6)"
    CASE RACE_HARPY
        RESULTS:0 = "鳥人(7)"
    CASE RACE_LAMIA
        RESULTS:0 = "蛇人(8)"
    CASEELSE
        RESULTS:0 = "未設定"
ENDSELECT
RETURN

@GET_JOB_STR, ARG
LOCAL:0 = ARG
SELECTCASE LOCAL:0
    CASE JOB_PALADIN
        RESULTS:1 = "聖騎士(1)"
    CASE JOB_MAGE
        RESULTS:1 = "法師(2)"
    CASE JOB_MERCHANT
        RESULTS:1 = "商人(3)"
    CASE JOB_BLACKSMITH
        RESULTS:1 = "鐵匠(4)"
    CASE JOB_HUNTER
        RESULTS:1 = "獵人(5)"
    CASE JOB_WARRIOR
        RESULTS:1 = "戰士(6)"
    CASE JOB_ASSASSIN
        RESULTS:1 = "刺客(7)"
    CASE JOB_DIVINER
        RESULTS:1 = "占卜師(8)"
    CASEELSE
        RESULTS:1 = "未設定"
ENDSELECT
RETURN

@TITLE_SCREEN
$TITLE_TOP
DRAWLINE
PRINTL  ERA ISEKAI
PRINTL  養成 × 經營 × 抽牌戰鬥
DRAWLINE
PRINTL  [1] 開始遊戲
PRINTL  [0] 結束
PRINTL
PRINTFORML 請輸入選項：
INPUT RESULT

IF RESULT == 1
    CALL GAME_LOOP
    RETURN
ELSEIF RESULT == 0
    QUIT
ELSE
    PRINTL 請輸入 1 或 0。
    GOTO TITLE_TOP
ENDIF

@GAME_LOOP
; ===== 每日主循環入口 =====
WHILE 1
    IF FLAG:DAY_PHASE == 1
        CALL PHASE_MORNING
    ELSEIF FLAG:DAY_PHASE == 2
        CALL PHASE_DAY
    ELSEIF FLAG:DAY_PHASE == 3
        CALL PHASE_NIGHT
    ELSE
        CALL SYS_RECOVER
    ENDIF
WEND
RETURN

@PHASE_MORNING
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／晨間】
IF TFLAG:MORNING_DONE == 0
    LOCAL:20 = 0
    LOCAL:21 = 0
    LOCAL:22 = 0
    LOCAL:23 = 0
    LOCAL:24 = 0
    LOCAL:25 = 0

    ; 首日保護：DAY 1 晨間不執行設施產出與維護費結算
    IF FLAG:BASE_DAY > 1
        ; 設施產出：工坊提供金錢/材料，訓練室與休息室提供少量補給回補
        LOCAL:20 = 40 + FLAG:BASE_FAC_LV_WORK * 60
        LOCAL:21 = 8 + FLAG:BASE_FAC_LV_WORK * 6
        LOCAL:22 = FLAG:BASE_FAC_LV_TRAIN * 2 + FLAG:BASE_FAC_LV_LOUNGE * 3

        FLAG:RES_MONEY += LOCAL:20
        FLAG:RES_MATERIAL += LOCAL:21
        FLAG:RES_SUPPLY += LOCAL:22

        ; 維護費結算：優先扣補給，不足再扣金錢
        LOCAL:10 = FLAG:BASE_FAC_LV_ROOM
        IF LOCAL:10 < 0
            LOCAL:10 = 0
        ELSEIF LOCAL:10 > ROOM_OWNER_MAX
            LOCAL:10 = ROOM_OWNER_MAX
        ENDIF

        FOR LOCAL, 0, LOCAL:10
            IF ROOM_OWNER:LOCAL == -1
                CONTINUE
            ENDIF

            LOCAL:1 = ROOM_OWNER:LOCAL
            LOCAL:2 = 3
            ; 房間等級折扣：每級 -5%，最多折扣至 50%
            LOCAL:7 = FLAG:BASE_FAC_LV_ROOM * 5
            IF LOCAL:7 > 50
                LOCAL:7 = 50
            ENDIF
            LOCAL:2 = LOCAL:2 * (100 - LOCAL:7) / 100
            LOCAL:3 = CFLAG:(LOCAL:1):CF_MAINT_COST_MOD
            LOCAL:2 = LOCAL:2 + LOCAL:2 * LOCAL:3 / 100
            IF LOCAL:2 < 1
                LOCAL:2 = 1
            ENDIF

            LOCAL:4 = LOCAL:2
            IF FLAG:RES_SUPPLY >= LOCAL:4
                FLAG:RES_SUPPLY -= LOCAL:4
                LOCAL:23 += LOCAL:4
                CONTINUE
            ENDIF

            LOCAL:5 = LOCAL:4 - FLAG:RES_SUPPLY
            LOCAL:23 += FLAG:RES_SUPPLY
            FLAG:RES_SUPPLY = 0

            LOCAL:6 = LOCAL:5 * 12
            IF FLAG:RES_MONEY >= LOCAL:6
                FLAG:RES_MONEY -= LOCAL:6
                LOCAL:24 += LOCAL:6
            ELSE
                LOCAL:24 += FLAG:RES_MONEY
                FLAG:RES_MONEY = 0
                LOCAL:25 += 1
            ENDIF
        NEXT
    ENDIF

    ; 工坊生產佇列推進：晨間天數遞減與完工發放
    LOCAL:30 = 0
    LOCAL:31 = 0
    LOCAL:32 = 0
    FOR LOCAL, 0, WORK_Q_MAX
        IF WORK_Q_REMAIN:LOCAL > 0
            WORK_Q_REMAIN:LOCAL -= 1
            IF WORK_Q_REMAIN:LOCAL < 0
                WORK_Q_REMAIN:LOCAL = 0
            ENDIF
            IF WORK_Q_REMAIN:LOCAL == 0 && WORK_Q_TYPE:LOCAL != 0
                LOCAL:31 = WORK_Q_TYPE:LOCAL
                ITEM:(LOCAL:31) += 1
                WORK_Q_TYPE:LOCAL = 0
                LOCAL:30 += 1
                IF LOCAL:32 == 0
                    LOCAL:32 = LOCAL:31
                ENDIF
            ENDIF
        ENDIF
    NEXT

    ; 防呆：資源不可低於 0
    IF FLAG:RES_MONEY < 0
        FLAG:RES_MONEY = 0
    ENDIF
    IF FLAG:RES_MATERIAL < 0
        FLAG:RES_MATERIAL = 0
    ENDIF
    IF FLAG:RES_SUPPLY < 0
        FLAG:RES_SUPPLY = 0
    ENDIF

    PRINTL --- 晨報 ---
    PRINTFORML 設施收益：金錢 +{LOCAL:20} / 材料 +{LOCAL:21} / 補給 +{LOCAL:22}
    PRINTFORML 維護扣減：補給 -{LOCAL:23} / 金錢 -{LOCAL:24}
    IF LOCAL:25 > 0
        PRINTFORML [警告] 有 {LOCAL:25} 名入住 NPC 維護費未足額支付！
    ENDIF
    IF LOCAL:30 > 0
        IF LOCAL:30 == 1
            PRINTFORML [工坊] 製作完成：%ITEMNAME:(LOCAL:32)%
        ELSE
            PRINTFORML [工坊] 製作完成：{LOCAL:30} 項（含 %ITEMNAME:(LOCAL:32)%）
        ENDIF
    ENDIF
    PRINTFORML 當前資源：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL} / 補給 {FLAG:RES_SUPPLY}
    TFLAG:MORNING_DONE = 1
ENDIF
PRINTL [1] 開始日間
INPUT RESULT
IF RESULT == 1
    FLAG:DAY_PHASE = 2
ENDIF
RETURN

@PHASE_DAY
$PHASE_DAY_MENU
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／日間】
PRINTL [1] 基地管理
PRINTL [2] 進入戰鬥（暫定）
PRINTL [9] 結束日間
INPUT RESULT

IF RESULT == 1
    CALL BASE_MENU
    GOTO PHASE_DAY_MENU
ELSEIF RESULT == 2
    TFLAG:RETURN_PHASE = 2
    CALL BATTLE_ENTER
    GOTO PHASE_DAY_MENU
ELSEIF RESULT == 9
    FLAG:DAY_PHASE = 3
ENDIF
RETURN

@PHASE_NIGHT
$PHASE_NIGHT_MENU
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／晚間】
PRINTL [1] 晚間行動（暫定）
PRINTL [2] 進入戰鬥（暫定）
PRINTL [9] 就寢
INPUT RESULT

IF RESULT == 1
    PRINTL 你完成了晚間整備。
    GOTO PHASE_NIGHT_MENU
ELSEIF RESULT == 2
    TFLAG:RETURN_PHASE = 3
    CALL BATTLE_ENTER
    GOTO PHASE_NIGHT_MENU
ELSEIF RESULT == 9
    ; 日末數值結算：入住 NPC 疲勞自然下降，過勞會降低心情
    LOCAL:10 = FLAG:BASE_FAC_LV_ROOM
    IF LOCAL:10 < 0
        LOCAL:10 = 0
    ELSEIF LOCAL:10 > ROOM_OWNER_MAX
        LOCAL:10 = ROOM_OWNER_MAX
    ENDIF

    FOR LOCAL, 0, LOCAL:10
        IF ROOM_OWNER:LOCAL == -1
            CONTINUE
        ENDIF

        LOCAL:1 = ROOM_OWNER:LOCAL
        LOCAL:2 = CFLAG:(LOCAL:1):CF_FATIGUE
        LOCAL:3 = 8 + FLAG:BASE_FAC_LV_LOUNGE * 2
        LOCAL:2 -= LOCAL:3
        IF LOCAL:2 < 0
            LOCAL:2 = 0
        ENDIF
        CFLAG:(LOCAL:1):CF_FATIGUE = LOCAL:2

        IF LOCAL:2 >= 80
            CFLAG:(LOCAL:1):CF_MOOD -= 8
        ELSEIF LOCAL:2 >= 60
            CFLAG:(LOCAL:1):CF_MOOD -= 3
        ELSE
            CFLAG:(LOCAL:1):CF_MOOD += 1
        ENDIF

        IF CFLAG:(LOCAL:1):CF_MOOD < 0
            CFLAG:(LOCAL:1):CF_MOOD = 0
        ELSEIF CFLAG:(LOCAL:1):CF_MOOD > 100
            CFLAG:(LOCAL:1):CF_MOOD = 100
        ENDIF
    NEXT

    CALL TRIGGER_NIGHT_EVENT

    ; 一天結束，推進到隔日晨間
    FLAG:BASE_DAY += 1
    FLAG:DAY_PHASE = 1
    TFLAG:MORNING_DONE = 0
ENDIF
RETURN

@BATTLE_ENTER
BASE:MASTER:BTL_MAXHP = 100
BASE:MASTER:BTL_HP = 100
BASE:MASTER:BTL_MAXEN = 10
BASE:MASTER:BTL_EN = 10

TFLAG:BATTLE_TURN = 1
TFLAG:HAND0 = 0
TFLAG:HAND1 = 0
TFLAG:HAND2 = 0
TFLAG:HAND3 = 0
TFLAG:TEMP_CARD = 0

CALL BATTLE_DRAW_CARDS
CALL BATTLE_UI_MAIN
RETURN

@BATTLE_DRAW_CARDS
FOR LOCAL, HAND0, HAND3 + 1
    IF TFLAG:LOCAL == 0
        ; 1=物理, 2=魔法, 3=防禦, 4=特殊
        TFLAG:LOCAL = 1 + RAND:4
    ENDIF
NEXT
TFLAG:TEMP_USED_THIS_TURN = 0
RETURN

@BATTLE_PRINT_ELEMENT_SLOT, ARG, ARG:1
LOCAL:30 = ARG
LOCAL:31 = ARG:1

IF LOCAL:31 == 0
    PRINTFORML [%LOCAL:30%] [空]
    RETURN
ENDIF

SELECTCASE LOCAL:31
    CASE ELEM_PHYS
        PRINTFORML [%LOCAL:30%] 【物理元素】
    CASE ELEM_MAG
        PRINTFORML [%LOCAL:30%] 【魔法元素】
    CASE ELEM_DEF
        PRINTFORML [%LOCAL:30%] 【防禦元素】
    CASE ELEM_SPEC
        PRINTFORML [%LOCAL:30%] 【特殊元素】
    CASEELSE
        PRINTFORML [%LOCAL:30%] [未知元素:{LOCAL:31}]
ENDSELECT
RETURN

@BATTLE_PRINT_TEMP_SLOT, ARG
LOCAL:30 = ARG

IF LOCAL:30 == 0
    PRINTL [T] Temp: [空]
    RETURN
ENDIF

SELECTCASE LOCAL:30
    CASE ELEM_PHYS
        PRINTL [T] Temp: 【物理元素】
    CASE ELEM_MAG
        PRINTL [T] Temp: 【魔法元素】
    CASE ELEM_DEF
        PRINTL [T] Temp: 【防禦元素】
    CASE ELEM_SPEC
        PRINTL [T] Temp: 【特殊元素】
    CASEELSE
        PRINTFORML [T] Temp: [未知元素:{LOCAL:30}]
ENDSELECT
RETURN

@BATTLE_UI_MAIN
$BATTLE_UI_MAIN_LOOP
DRAWLINE
PRINTFORML 【戰鬥】Turn {TFLAG:BATTLE_TURN}
PRINTFORML HP {BASE:MASTER:BTL_HP}/{BASE:MASTER:BTL_MAXHP} | EN {BASE:MASTER:BTL_EN}/{BASE:MASTER:BTL_MAXEN} | TempUsed {TFLAG:TEMP_USED_THIS_TURN}
DRAWLINE

PRINTL (技能映射提示區預留位置)
DRAWLINE

LOCAL:20 = TFLAG:HAND0
LOCAL:21 = TFLAG:HAND1
LOCAL:22 = TFLAG:HAND2
LOCAL:23 = TFLAG:HAND3
LOCAL:24 = TFLAG:TEMP_CARD

CALL BATTLE_PRINT_ELEMENT_SLOT, "H0", LOCAL:20
CALL BATTLE_PRINT_ELEMENT_SLOT, "H1", LOCAL:21
CALL BATTLE_PRINT_ELEMENT_SLOT, "H2", LOCAL:22
CALL BATTLE_PRINT_ELEMENT_SLOT, "H3", LOCAL:23
CALL BATTLE_PRINT_TEMP_SLOT, LOCAL:24

DRAWLINE
PRINTL [410] 選 H0  [411] 選 H1  [412] 選 H2  [413] 選 H3
PRINTL [420] Temp 存牌  [421] Temp 取牌
PRINTL [430] 確認出招
PRINTL [0] 逃跑並返回基地

INPUT RESULT
IF RESULT == 430
    TFLAG:BATTLE_TURN += 1
    CALL BATTLE_DRAW_CARDS
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 0
    RETURN
ELSE
    GOTO BATTLE_UI_MAIN_LOOP
ENDIF


@TEST_ADD_RANDOM_NPC
LOCAL:10 = 1 + RAND:2
ADDCHARA LOCAL:10

IF CHARANUM <= 1
    PRINTL 新角色加入失敗（未偵測到可用角色）。
    RETURN
ENDIF

LOCAL:11 = CHARANUM - 1
CFLAG:(LOCAL:11):CF_IS_RESIDENT = 0
CFLAG:(LOCAL:11):CF_ROOM_SLOT = 9999
CFLAG:(LOCAL:11):CF_RACE = 1 + RAND:8
CFLAG:(LOCAL:11):CF_JOB = 1 + RAND:8
CALL INIT_CHARA_STATS, LOCAL:11
CALL GET_RACE_STR, CFLAG:(LOCAL:11):CF_RACE
CALL GET_JOB_STR, CFLAG:(LOCAL:11):CF_JOB
PRINTFORML %CALLNAME:(LOCAL:11)% 已加入基地（%RESULTS:0% / %RESULTS:1%）。
RETURN

@SYS_RECOVER
PRINTL [警告] 偵測到非法 DAY_PHASE，已重置為晨間。
FLAG:DAY_PHASE = 1
RETURN


@TRIGGER_NIGHT_EVENT
; 晚間隨機事件擴充入口（預留）
RETURN
