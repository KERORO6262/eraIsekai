; 職責：系統啟動入口、全域初始化與標題畫面。
@EVENTFIRST
; ===== 系統啟動入口 =====
; 僅在新遊戲啟動時初始化，避免讀檔時覆蓋存檔數值
IF FLAG:SYS_INITIALIZED == 0
    CALL INIT_BASE_STATE
ENDIF
CALL TITLE_SCREEN
RETURN

@INIT_BASE_STATE
; ===== 全域初始化 =====
FLAG:SYS_INITIALIZED = 1

; 初始化玩家角色（0 號為 MASTER）
ADDCHARA 0
MASTER = 0

FLAG:BASE_DAY = 1
FLAG:DAY_PHASE = 1

; Core Loop 初始資源（可依平衡再調整）
FLAG:RES_MONEY = 1000
FLAG:RES_MATERIAL = 80
FLAG:RES_SUPPLY = 60

; 基地設施初始等級
FLAG:BASE_FAC_LV_TRAIN = 1
FLAG:BASE_FAC_LV_WORK = 1
FLAG:BASE_FAC_LV_LOUNGE = 1
FLAG:BASE_FAC_LV_ROOM = 1

CALL INIT_MASTER_STATS
CALL BASE_INIT
CALL BATTLE_INIT

; 當日流程保護旗標
TFLAG:MORNING_DONE = 0
TFLAG:RETURN_PHASE = 0
RETURN

@TITLE_SCREEN
$TITLE_TOP
DRAWLINE
PRINTL  ERA ISEKAI
PRINTL  養成 × 經營 × 抽牌戰鬥
DRAWLINE
PRINTL  [1] 開始遊戲
PRINTL  [0] 結束
PRINTL
PRINTFORML 請輸入選項：
INPUT RESULT

IF RESULT == 1
    CALL GAME_LOOP
    RETURN
ELSEIF RESULT == 0
    QUIT
ELSE
    PRINTL 請輸入 1 或 0。
    GOTO TITLE_TOP
ENDIF
