; 職責：每日流程狀態機（晨間、日間、晚間）與流程保底處理。
@GAME_LOOP
; ===== 每日主循環入口 =====
WHILE 1
    IF FLAG:DAY_PHASE == 1
        CALL PHASE_MORNING
    ELSEIF FLAG:DAY_PHASE == 2
        CALL PHASE_DAY
    ELSEIF FLAG:DAY_PHASE == 3
        CALL PHASE_NIGHT
    ELSE
        CALL SYS_RECOVER
    ENDIF
WEND
RETURN

@PHASE_MORNING
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／晨間】
IF TFLAG:MORNING_DONE == 0
    CALL BASE_EVENT_MORNING
    TFLAG:MORNING_DONE = 1
ENDIF
PRINTL [1] 開始日間
INPUT RESULT
IF RESULT == 1
    FLAG:DAY_PHASE = 2
ENDIF
RETURN

@PHASE_DAY
$PHASE_DAY_MENU
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／日間】
PRINTL [1] 基地管理
PRINTL [2] 進入戰鬥（暫定）
PRINTL [9] 結束日間
INPUT RESULT

IF RESULT == 1
    CALL BASE_MENU
    GOTO PHASE_DAY_MENU
ELSEIF RESULT == 2
    TFLAG:RETURN_PHASE = 2
    CALL BATTLE_PREPARATION
    CALL BATTLE_SETTLEMENT_REPORT
    GOTO PHASE_DAY_MENU
ELSEIF RESULT == 9
    FLAG:DAY_PHASE = 3
ENDIF
RETURN

@PHASE_NIGHT
$PHASE_NIGHT_MENU
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／晚間】
PRINTL [1] 晚間行動（暫定）
PRINTL [2] 進入戰鬥（暫定）
PRINTL [9] 就寢
INPUT RESULT

IF RESULT == 1
    PRINTL 你完成了晚間整備。
    GOTO PHASE_NIGHT_MENU
ELSEIF RESULT == 2
    TFLAG:RETURN_PHASE = 3
    CALL BATTLE_PREPARATION
    CALL BATTLE_SETTLEMENT_REPORT
    GOTO PHASE_NIGHT_MENU
ELSEIF RESULT == 9
    CALL CHARA_EVENT_NIGHT
    CALL TRIGGER_NIGHT_EVENT

    ; 一天結束，推進到隔日晨間
    FLAG:BASE_DAY += 1
    FLAG:DAY_PHASE = 1
    TFLAG:MORNING_DONE = 0
ENDIF
RETURN

@SYS_RECOVER
PRINTL [警告] 偵測到非法 DAY_PHASE，已重置為晨間。
FLAG:DAY_PHASE = 1
RETURN


@TRIGGER_NIGHT_EVENT
; 晚間隨機事件擴充入口（預留）
RETURN
