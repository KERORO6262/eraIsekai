@DEBUG_MAIN_MENU
$DEBUG_MAIN_TOP
DRAWLINE
PRINTL 【開發者選項 Debug Mode】
PRINTFORML 資源：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL} / 補給 {FLAG:RES_SUPPLY}
PRINTL [1] 資源修改
PRINTL [2] 產生隨機 NPC
PRINTL [3] NPC 編輯器
PRINTL [0] 返回基地選單
INPUT RESULT

IF RESULT == 0
    RETURN
ENDIF
IF RESULT == 1
    CALL DEBUG_RESOURCE_MENU
    GOTO DEBUG_MAIN_TOP
ENDIF
IF RESULT == 2
    CALL TEST_ADD_RANDOM_NPC
    GOTO DEBUG_MAIN_TOP
ENDIF
IF RESULT == 3
    CALL DEBUG_NPC_EDITOR
    GOTO DEBUG_MAIN_TOP
ENDIF

PRINTL 請輸入 0/1/2/3。
GOTO DEBUG_MAIN_TOP

@DEBUG_RESOURCE_MENU
$DEBUG_RESOURCE_TOP
DRAWLINE
PRINTL 【資源修改】
PRINTFORML 目前：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL} / 補給 {FLAG:RES_SUPPLY}
PRINTL [1] 金錢
PRINTL [2] 材料
PRINTL [3] 補給
PRINTL [0] 返回
INPUT RESULT

IF RESULT == 0
    RETURN
ENDIF
IF RESULT < 1 || RESULT > 3
    PRINTL 請輸入 0~3。
    GOTO DEBUG_RESOURCE_TOP
ENDIF

LOCAL:0 = RESULT
PRINTL [1] 增加（可輸入負數）
PRINTL [2] 直接設定
PRINTL [0] 取消
INPUT RESULT
LOCAL:1 = RESULT
IF LOCAL:1 == 0
    GOTO DEBUG_RESOURCE_TOP
ENDIF
IF LOCAL:1 != 1 && LOCAL:1 != 2
    PRINTL 請輸入 0/1/2。
    GOTO DEBUG_RESOURCE_TOP
ENDIF

PRINTL 請輸入數值：
INPUT RESULT
LOCAL:2 = RESULT

IF LOCAL:0 == 1
    IF LOCAL:1 == 1
        FLAG:RES_MONEY += LOCAL:2
    ELSE
        FLAG:RES_MONEY = LOCAL:2
    ENDIF
    IF FLAG:RES_MONEY < 0
        FLAG:RES_MONEY = 0
    ENDIF
ELSEIF LOCAL:0 == 2
    IF LOCAL:1 == 1
        FLAG:RES_MATERIAL += LOCAL:2
    ELSE
        FLAG:RES_MATERIAL = LOCAL:2
    ENDIF
    IF FLAG:RES_MATERIAL < 0
        FLAG:RES_MATERIAL = 0
    ENDIF
ELSE
    IF LOCAL:1 == 1
        FLAG:RES_SUPPLY += LOCAL:2
    ELSE
        FLAG:RES_SUPPLY = LOCAL:2
    ENDIF
    IF FLAG:RES_SUPPLY < 0
        FLAG:RES_SUPPLY = 0
    ENDIF
ENDIF

PRINTFORML 修改完成：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL} / 補給 {FLAG:RES_SUPPLY}
GOTO DEBUG_RESOURCE_TOP

@DEBUG_NPC_EDITOR
$DEBUG_NPC_EDITOR_TOP
DRAWLINE
PRINTL 【NPC 編輯器】
IF CHARANUM <= 1
    PRINTL 目前沒有可編輯的 NPC。
    RETURN
ENDIF

FOR LOCAL, 1, CHARANUM - 1
    CALL GET_RACE_STR, CFLAG:(LOCAL):CF_RACE
    CALL GET_JOB_STR, CFLAG:(LOCAL):CF_JOB
    PRINTFORML [{LOCAL}] %CALLNAME:(LOCAL)% [%RESULTS:0% / %RESULTS:1%] | SPD {BASE:(LOCAL):BTL_SPEED} / CRIT {BASE:(LOCAL):BTL_CRIT}
NEXT
PRINTL [0] 返回
INPUT RESULT

IF RESULT == 0
    RETURN
ENDIF
IF RESULT < 1 || RESULT >= CHARANUM
    PRINTL 請輸入有效 NPC 編號。
    GOTO DEBUG_NPC_EDITOR_TOP
ENDIF

CALL DEBUG_NPC_EDITOR_DETAIL, RESULT
GOTO DEBUG_NPC_EDITOR_TOP

@DEBUG_NPC_EDITOR_DETAIL, ARG
$DEBUG_NPC_DETAIL_TOP
TARGET = ARG
CALL GET_RACE_STR, CFLAG:TARGET:CF_RACE
CALL GET_JOB_STR, CFLAG:TARGET:CF_JOB
DRAWLINE
PRINTFORML 【NPC 編輯：%CALLNAME:TARGET%】
PRINTFORML 種族/職業：%RESULTS:0% / %RESULTS:1%
PRINTFORML BASE：SPD {BASE:TARGET:BTL_SPEED} / CRIT {BASE:TARGET:BTL_CRIT} / PATK {BASE:TARGET:BTL_PATK} / MATK {BASE:TARGET:BTL_MATK} / SATK {BASE:TARGET:BTL_SATK} / PDEF {BASE:TARGET:BTL_PDEF} / MDEF {BASE:TARGET:BTL_MDEF}
PRINTL [1] 修改種族與職業（自動重算）
PRINTL [2] 手動修改 BASE
PRINTL [0] 返回
INPUT RESULT

IF RESULT == 0
    RETURN
ENDIF
IF RESULT == 1
    PRINTL 請輸入種族 ID（1~8）：
    INPUT RESULT
    LOCAL:0 = RESULT
    PRINTL 請輸入職業 ID（1~8）：
    INPUT RESULT
    LOCAL:1 = RESULT
    CFLAG:TARGET:CF_RACE = LIMIT(LOCAL:0, 1, 8)
    CFLAG:TARGET:CF_JOB = LIMIT(LOCAL:1, 1, 8)
    CALL INIT_CHARA_STATS, TARGET
    PRINTL 已更新種族/職業並重新計算 BASE。
    GOTO DEBUG_NPC_DETAIL_TOP
ENDIF
IF RESULT == 2
    CALL DEBUG_NPC_EDIT_BASE, TARGET
    GOTO DEBUG_NPC_DETAIL_TOP
ENDIF

PRINTL 請輸入 0/1/2。
GOTO DEBUG_NPC_DETAIL_TOP

@DEBUG_NPC_EDIT_BASE, ARG
$DEBUG_NPC_BASE_TOP
TARGET = ARG
DRAWLINE
PRINTFORML 【手動修改 BASE：%CALLNAME:TARGET%】
PRINTFORML [1] 速度 {BASE:TARGET:BTL_SPEED}
PRINTFORML [2] 暴擊 {BASE:TARGET:BTL_CRIT}
PRINTFORML [3] 物攻 {BASE:TARGET:BTL_PATK}
PRINTFORML [4] 魔攻 {BASE:TARGET:BTL_MATK}
PRINTFORML [5] 特攻 {BASE:TARGET:BTL_SATK}
PRINTFORML [6] 物防 {BASE:TARGET:BTL_PDEF}
PRINTFORML [7] 魔防 {BASE:TARGET:BTL_MDEF}
PRINTL [0] 返回
INPUT RESULT

IF RESULT == 0
    RETURN
ENDIF
IF RESULT < 1 || RESULT > 7
    PRINTL 請輸入 0~7。
    GOTO DEBUG_NPC_BASE_TOP
ENDIF

PRINTL [1] 增加（可輸入負數）
PRINTL [2] 直接設定
INPUT RESULT
LOCAL:0 = RESULT
IF LOCAL:0 != 1 && LOCAL:0 != 2
    PRINTL 請輸入 1 或 2。
    GOTO DEBUG_NPC_BASE_TOP
ENDIF

PRINTL 請輸入數值：
INPUT RESULT
LOCAL:1 = RESULT

LOCAL:2 = BTL_SPEED
IF RESULT == 2
    LOCAL:2 = BTL_CRIT
ELSEIF RESULT == 3
    LOCAL:2 = BTL_PATK
ELSEIF RESULT == 4
    LOCAL:2 = BTL_MATK
ELSEIF RESULT == 5
    LOCAL:2 = BTL_SATK
ELSEIF RESULT == 6
    LOCAL:2 = BTL_PDEF
ELSEIF RESULT == 7
    LOCAL:2 = BTL_MDEF
ENDIF

IF LOCAL:0 == 1
    BASE:TARGET:(LOCAL:2) += LOCAL:1
ELSE
    BASE:TARGET:(LOCAL:2) = LOCAL:1
ENDIF
IF BASE:TARGET:(LOCAL:2) < 0
    BASE:TARGET:(LOCAL:2) = 0
ENDIF

PRINTL BASE 已更新。
GOTO DEBUG_NPC_BASE_TOP
