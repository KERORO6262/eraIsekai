@BASE_MENU
$BASE_MENU_TOP
CALL BASE_SYNC_DAILY_USES
DRAWLINE
PRINTL 【基地管理】
PRINTFORML 資源：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL} / 補給 {FLAG:RES_SUPPLY}
PRINTFORML 設施：訓練 Lv.{FLAG:BASE_FAC_LV_TRAIN} / 工坊 Lv.{FLAG:BASE_FAC_LV_WORK} / 休息 Lv.{FLAG:BASE_FAC_LV_LOUNGE} / 房間 Lv.{FLAG:BASE_FAC_LV_ROOM}
DRAWLINE
PRINTL --- 住宿 NPC 狀態 ---
LOCAL:20 = FLAG:BASE_FAC_LV_ROOM
IF LOCAL:20 < 0
    LOCAL:20 = 0
ELSEIF LOCAL:20 > ROOM_OWNER_MAX
    LOCAL:20 = ROOM_OWNER_MAX
ENDIF
LOCAL:21 = 0
FOR LOCAL, 0, LOCAL:20
    IF ROOM_OWNER:LOCAL == -1
        CONTINUE
    ENDIF

    LOCAL:1 = ROOM_OWNER:LOCAL
    PRINTFORML [S{LOCAL}] %CALLNAME:(LOCAL:1)% | 好感 {CFLAG:(LOCAL:1):CF_BOND_LV} | 心情 {CFLAG:(LOCAL:1):CF_MOOD} | 疲勞 {CFLAG:(LOCAL:1):CF_FATIGUE}
    LOCAL:21 += 1
NEXT
IF LOCAL:21 == 0
    PRINTL （目前無住宿 NPC）
ENDIF
DRAWLINE
PRINTL [1] 訓練室
PRINTL [2] 工坊
PRINTL [3] 休息室
PRINTL [4] 房間管理
PRINTL [0] 測試：獲得金錢 +500 / 材料 +50
PRINTL [9] 返回日間選單
INPUT RESULT

IF RESULT == 1
    CALL FACILITY_TRAIN
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 2
    CALL FACILITY_WORK
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 3
    CALL FACILITY_LOUNGE
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 4
    CALL FACILITY_ROOM
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 0
    FLAG:RES_MONEY += 500
    FLAG:RES_MATERIAL += 50
    PRINTL 已獲得測試資源：金錢 +500 / 材料 +50。
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 9
    RETURN
ENDIF

PRINTL 請輸入 0/1/2/3/4/9。
GOTO BASE_MENU_TOP

@FACILITY_TRAIN
$FACILITY_TRAIN_TOP
CALL BASE_SYNC_DAILY_USES
LOCAL:10 = 1 + FLAG:BASE_FAC_LV_TRAIN / 2
IF LOCAL:10 < 1
    LOCAL:10 = 1
ENDIF
LOCAL:11 = 5 + FLAG:BASE_FAC_LV_TRAIN * 2
LOCAL:12 = 15 + FLAG:BASE_FAC_LV_TRAIN * 3
DRAWLINE
PRINTFORML 【訓練室 Lv.{FLAG:BASE_FAC_LV_TRAIN}】
PRINTFORML 今日使用次數：{TFLAG:50}/{LOCAL:10}
PRINTL [1] 基礎訓練（消耗 5 點補給，增加疲勞以提升訓練倍率）
IF FLAG:BASE_FAC_LV_TRAIN >= 3
    PRINTFORML [2] 專項訓練（消耗 10 補給 / 疲勞 +30 / 訓練倍率 +{LOCAL:12}）
ENDIF
PRINTL [8] 升級訓練室
PRINTL [9] 返回基地選單
INPUT RESULT

IF RESULT == 9
    RETURN
ENDIF
IF RESULT == 8
    CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_TRAIN, "訓練室"
    IF RESULT == 1
        FLAG:BASE_FAC_LV_TRAIN += 1
    ENDIF
    GOTO FACILITY_TRAIN_TOP
ENDIF
IF RESULT != 1 && RESULT != 2
    PRINTL 請輸入 1、2、8 或 9。
    GOTO FACILITY_TRAIN_TOP
ENDIF
IF RESULT == 2 && FLAG:BASE_FAC_LV_TRAIN < 3
    PRINTL 訓練室需達 Lv.3 才能啟用專項訓練。
    GOTO FACILITY_TRAIN_TOP
ENDIF

IF TFLAG:50 >= LOCAL:10
    PRINTL 今日訓練次數已達上限。
    GOTO FACILITY_TRAIN_TOP
ENDIF

LOCAL:13 = 5
LOCAL:14 = 20
LOCAL:15 = LOCAL:11
IF RESULT == 2
    LOCAL:13 = 10
    LOCAL:14 = 30
    LOCAL:15 = LOCAL:12
ENDIF
IF FLAG:RES_SUPPLY < LOCAL:13
    PRINTL 補給不足，無法進行訓練。
    GOTO FACILITY_TRAIN_TOP
ENDIF

CALL SELECT_RESIDENT_NPC
IF RESULT < 0
    GOTO FACILITY_TRAIN_TOP
ENDIF
TARGET = RESULT
IF CFLAG:TARGET:CF_FATIGUE >= 80
    PRINTFORML [%CALLNAME:TARGET%] 疲勞過高，今日不適合訓練。
    GOTO FACILITY_TRAIN_TOP
ENDIF

FLAG:RES_SUPPLY -= LOCAL:13
IF FLAG:RES_SUPPLY < 0
    FLAG:RES_SUPPLY = 0
ENDIF

CFLAG:TARGET:CF_FATIGUE += LOCAL:14
IF CFLAG:TARGET:CF_FATIGUE > 100
    CFLAG:TARGET:CF_FATIGUE = 100
ENDIF
CFLAG:TARGET:CF_TRAIN_MOD += LOCAL:15
IF CFLAG:TARGET:CF_TRAIN_MOD > 200
    CFLAG:TARGET:CF_TRAIN_MOD = 200
ENDIF

TFLAG:50 += 1
PRINTFORML 訓練完成：[%CALLNAME:TARGET%]（疲勞 {CFLAG:TARGET:CF_FATIGUE} / 訓練倍率 {CFLAG:TARGET:CF_TRAIN_MOD}）
GOTO FACILITY_TRAIN_TOP

@FACILITY_WORK
$FACILITY_WORK_TOP
LOCAL:10 = 1 + FLAG:BASE_FAC_LV_WORK / 2
IF LOCAL:10 < 1
    LOCAL:10 = 1
ELSEIF LOCAL:10 > WORK_Q_MAX
    LOCAL:10 = WORK_Q_MAX
ENDIF
DRAWLINE
PRINTFORML 【工坊 Lv.{FLAG:BASE_FAC_LV_WORK}】
LOCAL:12 = 0
FOR LOCAL, 0, LOCAL:10
    IF WORK_Q_TYPE:LOCAL != 0
        LOCAL:12 += 1
    ENDIF
NEXT
PRINTFORML 生產槽位狀態：{LOCAL:12} / {LOCAL:10} (工坊升級可解鎖更多，上限 {WORK_Q_MAX})
PRINTL --- 生產佇列 ---
FOR LOCAL, 0, LOCAL:10
    IF WORK_Q_TYPE:LOCAL == 0
        PRINTFORML [槽位{LOCAL}] [空閒]
    ELSE
        PRINTFORML [槽位{LOCAL}] %ITEMNAME:(WORK_Q_TYPE:LOCAL)%（剩餘 {WORK_Q_REMAIN:LOCAL} 天）
    ENDIF
NEXT
PRINTL
PRINTL [1] 材料轉補給（消耗 10 材料）
PRINTL [2] 製作卡牌
PRINTL [8] 升級工坊
PRINTL [9] 返回基地選單
INPUT RESULT

IF RESULT == 9
    RETURN
ENDIF
IF RESULT == 8
    CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_WORK, "工坊"
    IF RESULT == 1
        FLAG:BASE_FAC_LV_WORK += 1
    ENDIF
    GOTO FACILITY_WORK_TOP
ENDIF

IF RESULT == 1
    LOCAL:20 = 10
    LOCAL:21 = 5 + FLAG:BASE_FAC_LV_WORK * 2
    IF FLAG:RES_MATERIAL < LOCAL:20
        PRINTL 材料不足，無法轉換補給。
        GOTO FACILITY_WORK_TOP
    ENDIF

    FLAG:RES_MATERIAL -= LOCAL:20
    FLAG:RES_SUPPLY += LOCAL:21
    IF FLAG:RES_MATERIAL < 0
        FLAG:RES_MATERIAL = 0
    ENDIF
    IF FLAG:RES_SUPPLY < 0
        FLAG:RES_SUPPLY = 0
    ENDIF
    PRINTFORML 轉換完成：材料 -{LOCAL:20} / 補給 +{LOCAL:21}
    GOTO FACILITY_WORK_TOP
ENDIF

IF RESULT == 2
    CALL FACILITY_WORK_CRAFT_CARD, LOCAL:10
    GOTO FACILITY_WORK_TOP
ENDIF

PRINTL 請輸入 1、2、8 或 9。
GOTO FACILITY_WORK_TOP

@FACILITY_WORK_CRAFT_CARD, ARG
LOCAL:10 = ARG
LOCAL:11 = -1
FOR LOCAL, 0, LOCAL:10
    IF WORK_Q_TYPE:LOCAL == 0
        LOCAL:11 = LOCAL
        BREAK
    ENDIF
NEXT
IF LOCAL:11 < 0
    PRINTL 所有可用槽位皆在生產中，請等待晨間完成結算。
    RETURN
ENDIF

PRINTL --- 可製作卡牌 ---
PRINTL [10001] 斬擊（需求：工坊 Lv.1 / 材料 20 / 1 天）
PRINTL [10002] 重擊（需求：工坊 Lv.2 / 材料 30 / 2 天）
PRINTL [10003] 格擋（需求：工坊 Lv.1 / 材料 15 / 1 天）
PRINTL [10004] 破甲（需求：工坊 Lv.3 / 材料 35 / 2 天）
PRINTL [10005] 專注（需求：工坊 Lv.2 / 材料 25 / 1 天）
PRINTL [99] 取消
INPUT RESULT
IF RESULT == 99
    RETURN
ENDIF
IF RESULT < 10001 || RESULT > 10005
    PRINTL 請輸入 10001~10005。
    RETURN
ENDIF

LOCAL:20 = RESULT
LOCAL:21 = 1
LOCAL:22 = 20
LOCAL:23 = 1
IF LOCAL:20 == 10002
    LOCAL:21 = 2
    LOCAL:22 = 30
    LOCAL:23 = 2
ELSEIF LOCAL:20 == 10003
    LOCAL:21 = 1
    LOCAL:22 = 15
    LOCAL:23 = 1
ELSEIF LOCAL:20 == 10004
    LOCAL:21 = 3
    LOCAL:22 = 35
    LOCAL:23 = 2
ELSEIF LOCAL:20 == 10005
    LOCAL:21 = 2
    LOCAL:22 = 25
    LOCAL:23 = 1
ENDIF

IF FLAG:BASE_FAC_LV_WORK < LOCAL:21
    PRINTFORML 工坊等級不足：此配方需要工坊 Lv.{LOCAL:21}。
    RETURN
ENDIF
IF FLAG:RES_MATERIAL < LOCAL:22
    PRINTFORML 材料不足：需要 {LOCAL:22}。
    RETURN
ENDIF

FLAG:RES_MATERIAL -= LOCAL:22
IF FLAG:RES_MATERIAL < 0
    FLAG:RES_MATERIAL = 0
ENDIF
WORK_Q_TYPE:(LOCAL:11) = LOCAL:20
WORK_Q_REMAIN:(LOCAL:11) = LOCAL:23
PRINTFORML 已投入槽位{LOCAL:11}：%ITEMNAME:(LOCAL:20)%（{LOCAL:23} 天）
RETURN

@FACILITY_LOUNGE
$FACILITY_LOUNGE_TOP
CALL BASE_SYNC_DAILY_USES
LOCAL:10 = 1 + FLAG:BASE_FAC_LV_LOUNGE / 2
IF LOCAL:10 < 1
    LOCAL:10 = 1
ENDIF
LOCAL:11 = 20 + FLAG:BASE_FAC_LV_LOUNGE * 5
LOCAL:12 = 30 + FLAG:BASE_FAC_LV_LOUNGE * 5
IF LOCAL:12 > 100
    LOCAL:12 = 100
ENDIF
DRAWLINE
PRINTFORML 【休息室 Lv.{FLAG:BASE_FAC_LV_LOUNGE}】
PRINTFORML 今日互動次數：{TFLAG:51}/{LOCAL:10}
PRINTL [1] 日常交流/安撫（大幅減緩疲勞、改善心情，有機會提升好感）
PRINTL [8] 升級休息室
PRINTL [9] 返回基地選單
INPUT RESULT

IF RESULT == 9
    RETURN
ENDIF
IF RESULT == 8
    CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_LOUNGE, "休息室"
    IF RESULT == 1
        FLAG:BASE_FAC_LV_LOUNGE += 1
    ENDIF
    GOTO FACILITY_LOUNGE_TOP
ENDIF
IF RESULT != 1
    PRINTL 請輸入 1、8 或 9。
    GOTO FACILITY_LOUNGE_TOP
ENDIF

IF TFLAG:51 >= LOCAL:10
    PRINTL 今日休息室互動次數已達上限。
    GOTO FACILITY_LOUNGE_TOP
ENDIF

CALL SELECT_RESIDENT_NPC
IF RESULT < 0
    GOTO FACILITY_LOUNGE_TOP
ENDIF
TARGET = RESULT

CFLAG:TARGET:CF_FATIGUE -= LOCAL:11
IF CFLAG:TARGET:CF_FATIGUE < 0
    CFLAG:TARGET:CF_FATIGUE = 0
ENDIF
CFLAG:TARGET:CF_MOOD += 10
IF CFLAG:TARGET:CF_MOOD > 100
    CFLAG:TARGET:CF_MOOD = 100
ENDIF
IF RAND:100 < LOCAL:12
    CFLAG:TARGET:CF_BOND_LV += 1
    IF CFLAG:TARGET:CF_BOND_LV > 10
        CFLAG:TARGET:CF_BOND_LV = 10
    ENDIF
    LOCAL:2 = 1
ELSE
    LOCAL:2 = 0
ENDIF

TFLAG:51 += 1
IF LOCAL:2 == 1
    PRINTFORML 交流順利：[%CALLNAME:TARGET%]（疲勞 {CFLAG:TARGET:CF_FATIGUE} / 心情 {CFLAG:TARGET:CF_MOOD} / 好感 {CFLAG:TARGET:CF_BOND_LV}）
ELSE
    PRINTFORML 安撫完成：[%CALLNAME:TARGET%]（疲勞 {CFLAG:TARGET:CF_FATIGUE} / 心情 {CFLAG:TARGET:CF_MOOD}）
ENDIF
GOTO FACILITY_LOUNGE_TOP

@FACILITY_ROOM
$ROOM_MENU_TOP
DRAWLINE
PRINTFORML 【房間管理 Lv.{FLAG:BASE_FAC_LV_ROOM}】
LOCAL:20 = FLAG:BASE_FAC_LV_ROOM
IF LOCAL:20 < 0
    LOCAL:20 = 0
ELSEIF LOCAL:20 > ROOM_OWNER_MAX
    LOCAL:20 = ROOM_OWNER_MAX
ENDIF
PRINTL
PRINTL --- 槽位狀態 ---
IF LOCAL:20 == 0
    PRINTL （尚未解鎖任何槽位，請先升級房間管理）
ENDIF
FOR LOCAL, 0, LOCAL:20
    IF ROOM_OWNER:LOCAL == -1
        PRINTFORML [{LOCAL + 1}] 槽位 {LOCAL + 1}：[空]
    ELSE
        PRINTFORML [{LOCAL + 1}] 槽位 {LOCAL + 1}：[%CALLNAME:(ROOM_OWNER:LOCAL)%]
    ENDIF
NEXT
PRINTL
PRINTL [1~槽位上限] 選擇槽位
PRINTL [90] 升級房間管理
PRINTL [99] 返回基地選單
INPUT RESULT

IF RESULT == 99
    RETURN
ENDIF
IF RESULT == 90
    CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_ROOM, "房間管理"
    IF RESULT == 1
        FLAG:BASE_FAC_LV_ROOM += 1
    ENDIF
    GOTO ROOM_MENU_TOP
ENDIF
IF RESULT < 1 || RESULT > LOCAL:20
    PRINTL 無效的槽位編號。
    GOTO ROOM_MENU_TOP
ENDIF

LOCAL = RESULT - 1
IF ROOM_OWNER:LOCAL == -1
    CALL ROOM_ASSIGN_MENU, LOCAL
ELSE
    CALL ROOM_EVICT_MENU, LOCAL
ENDIF
GOTO ROOM_MENU_TOP

@ROOM_ASSIGN_MENU, ARG
$ROOM_ASSIGN_TOP
LOCAL = ARG
PRINTFORML 【槽位 {LOCAL + 1}：入住分配】
PRINTL 可入住 NPC：
LOCAL:10 = 0

FOR LOCAL:11, 1, CHARANUM
    IF CFLAG:(LOCAL:11):CF_IS_RESIDENT != 0
        CONTINUE
    ENDIF

    PRINTFORML [{LOCAL:11}] %CALLNAME:(LOCAL:11)%
    LOCAL:10 = 1
NEXT
IF LOCAL:10 == 0
    PRINTL （目前沒有可入住的 NPC）
    PRINTL [99] 取消
    INPUT RESULT
    RETURN
ENDIF

PRINTL [99] 取消
INPUT RESULT
IF RESULT == 99
    RETURN
ENDIF
IF RESULT < 1 || RESULT >= CHARANUM
    PRINTL 請輸入有效 NPC 編號。
    GOTO ROOM_ASSIGN_TOP
ENDIF
TARGET = RESULT
IF CFLAG:TARGET:CF_IS_RESIDENT != 0
    PRINTL 該 NPC 已經入住。
    GOTO ROOM_ASSIGN_TOP
ENDIF

ROOM_OWNER:LOCAL = TARGET
CFLAG:TARGET:CF_IS_RESIDENT = 1
CFLAG:TARGET:CF_ROOM_SLOT = LOCAL
PRINTFORML 已安排 [%CALLNAME:TARGET%] 入住槽位 {LOCAL + 1}。
RETURN

@ROOM_EVICT_MENU, ARG
LOCAL = ARG
TARGET = ROOM_OWNER:LOCAL
PRINTFORML 【槽位 {LOCAL + 1}：[%CALLNAME:TARGET%]】
PRINTL [1] 撤離
PRINTL [99] 取消
INPUT RESULT
IF RESULT != 1
    RETURN
ENDIF

CFLAG:TARGET:CF_IS_RESIDENT = 0
CFLAG:TARGET:CF_ROOM_SLOT = 9999
ROOM_OWNER:LOCAL = -1
PRINTL 已撤離。
RETURN

@BASE_SYNC_DAILY_USES
IF TFLAG:52 != FLAG:BASE_DAY
    TFLAG:52 = FLAG:BASE_DAY
    TFLAG:50 = 0
    TFLAG:51 = 0
ENDIF
RETURN

@SELECT_RESIDENT_NPC
LOCAL:20 = FLAG:BASE_FAC_LV_ROOM
IF LOCAL:20 < 0
    LOCAL:20 = 0
ELSEIF LOCAL:20 > ROOM_OWNER_MAX
    LOCAL:20 = ROOM_OWNER_MAX
ENDIF

PRINTL --- 可選擇的住宿 NPC ---
LOCAL:21 = 0
FOR LOCAL, 0, LOCAL:20
    IF ROOM_OWNER:LOCAL == -1
        CONTINUE
    ENDIF

    LOCAL:1 = ROOM_OWNER:LOCAL
    PRINTFORML [{LOCAL:1}] %CALLNAME:(LOCAL:1)% | 好感 {CFLAG:(LOCAL:1):CF_BOND_LV} | 心情 {CFLAG:(LOCAL:1):CF_MOOD} | 疲勞 {CFLAG:(LOCAL:1):CF_FATIGUE}
    LOCAL:21 = 1
NEXT
IF LOCAL:21 == 0
    PRINTL （目前沒有住宿 NPC）
    WAIT
    RETURN -1
ENDIF

PRINTL [99] 取消
INPUT RESULT
IF RESULT == 99
    RETURN -1
ENDIF
FOR LOCAL, 0, LOCAL:20
    IF ROOM_OWNER:LOCAL == RESULT
        RETURN RESULT
    ENDIF
NEXT
PRINTL 請輸入有效的住宿 NPC 編號。
WAIT
RETURN -1

@FACILITY_UPGRADE_MENU, ARG, ARGS
$FACILITY_MENU_LOOP
LOCAL = ARG
LOCAL:1 = 300 + LOCAL * 250 + LOCAL * LOCAL * 120
LOCAL:2 = 80 + LOCAL * 60 + LOCAL * LOCAL * 20

DRAWLINE
PRINTFORML 【%ARGS%】
PRINTFORML 目前等級：Lv.{LOCAL}
PRINTFORML 升級消耗：金錢 {LOCAL:1} / 材料 {LOCAL:2}
PRINTFORML 持有資源：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL}
PRINTL [1] 升級
PRINTL [9] 返回基地選單
INPUT RESULT

IF RESULT == 9
    RETURN 0
ENDIF
IF RESULT != 1
    PRINTL 請輸入 1 或 9。
    GOTO FACILITY_MENU_LOOP
ENDIF

IF FLAG:RES_MONEY < LOCAL:1
    PRINTL 金錢不足，無法升級。
    RETURN 0
ENDIF
IF FLAG:RES_MATERIAL < LOCAL:2
    PRINTL 材料不足，無法升級。
    RETURN 0
ENDIF

FLAG:RES_MONEY -= LOCAL:1
FLAG:RES_MATERIAL -= LOCAL:2
PRINTFORML %ARGS% 升級成功！
RETURN 1
