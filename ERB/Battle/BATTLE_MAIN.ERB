; ERA ISEKAI - Battle Module
; ==========================================

@INIT_PARTY_STATE
IF PARTY_MEMBERS:0 != MASTER
    PARTY_MEMBERS:0 = MASTER
ENDIF
PARTY_MEMBERS:1 = -1
PARTY_MEMBERS:2 = -1
PARTY_MEMBERS:3 = -1
RETURN

@BATTLE_PREPARATION
$BATTLE_PREPARATION_TOP
DRAWLINE
PRINTL 【戰前準備：隊伍編組】
IF PARTY_MEMBERS:0 == MASTER
    PRINTL [100] [X] 取消出戰：MASTER (主角)
ELSE
    PRINTL [100] [ ] 選擇出戰：MASTER (主角)
ENDIF
PRINTL [101] [ ] 隊友槽位 1（未實裝）
PRINTL [102] [ ] 隊友槽位 2（未實裝）
PRINTL [103] [ ] 隊友槽位 3（未實裝）
DRAWLINE
PRINTL [1] 確認出戰 (打木人樁)
PRINTL [0] 返回基地
INPUT RESULT

IF RESULT == 100
    IF PARTY_MEMBERS:0 == MASTER
        PARTY_MEMBERS:0 = -1
    ELSE
        PARTY_MEMBERS:0 = MASTER
    ENDIF
    GOTO BATTLE_PREPARATION_TOP
ENDIF
IF RESULT == 1
    LOCAL:20 = 0
    FOR LOCAL, 0, 3
        IF PARTY_MEMBERS:LOCAL != -1
            LOCAL:20 += 1
        ENDIF
    NEXT
    IF LOCAL:20 <= 0
        PRINTL 必須至少安排一名角色出戰！
        GOTO BATTLE_PREPARATION_TOP
    ENDIF

    CALL GENERATE_DUMMY_ENEMY
    CALL BATTLE_ENTER
    RETURN
ENDIF
IF RESULT == 0
    RETURN
ENDIF
PRINTL 請輸入 100、1 或 0。
GOTO BATTLE_PREPARATION_TOP

@BATTLE_ENTER
CALL INIT_MASTER_STATS

TFLAG:BATTLE_TURN = 1
TFLAG:HAND0 = 0
TFLAG:HAND1 = 0
TFLAG:HAND2 = 0
TFLAG:HAND3 = 0
TFLAG:TEMP_CARD = 0

CALL BATTLE_DRAW_CARDS
CALL BATTLE_UI_MAIN
RETURN

@GENERATE_DUMMY_ENEMY
ADDVOIDCHARA
TARGET = CHARANUM - 1
TFLAG:BATTLE_TARGET = TARGET
CALLNAME:TARGET = "木人樁"
BASE:TARGET:BTL_MAXHP = 500
BASE:TARGET:BTL_HP = 500
BASE:TARGET:BTL_PATK = 10
BASE:TARGET:BTL_MATK = 0
BASE:TARGET:BTL_PDEF = 0
BASE:TARGET:BTL_MDEF = 0
RETURN

@BATTLE_DRAW_CARDS
FOR LOCAL, HAND0, HAND3 + 1
    IF TFLAG:LOCAL == 0
        ; 1=物理, 2=魔法, 3=防禦, 4=特殊
        TFLAG:LOCAL = 1 + RAND:4
    ENDIF
NEXT

TFLAG:TEMP_USED_THIS_TURN = 0
TFLAG:UI_HAND0_SEL = 0
TFLAG:UI_HAND1_SEL = 0
TFLAG:UI_HAND2_SEL = 0
TFLAG:UI_HAND3_SEL = 0
TFLAG:UI_TEMP_SEL = 0
TFLAG:TEMP_BUFF_PATK = 0
TFLAG:TEMP_BUFF_MATK = 0
TFLAG:TEMP_BUFF_PDEF = 0
TFLAG:TEMP_BUFF_MDEF = 0
RETURN

@BATTLE_UI_PRINT_HAND_SLOT, ARG, ARG:1, ARG:2, ARG:3
; ARG=手牌索引(0~3), ARG:1=元素ID, ARG:2=選取狀態(0/1), ARG:3=指令編號(410~413)
IF ARG:1 == 0
    PRINTFORML [{ARG:3}] 槽位 H{ARG}: [空]
    RETURN
ENDIF

IF ARG:2 == 1
    RESULTS:10 = "已選取 [X]"
ELSE
    RESULTS:10 = "未選取 [ ]"
ENDIF

SELECTCASE ARG:1
    CASE ELEM_PHYS
        PRINTFORML [{ARG:3}] 槽位 H{ARG}: 【物理元素】 (狀態: %RESULTS:10%)
    CASE ELEM_MAG
        PRINTFORML [{ARG:3}] 槽位 H{ARG}: 【魔法元素】 (狀態: %RESULTS:10%)
    CASE ELEM_DEF
        PRINTFORML [{ARG:3}] 槽位 H{ARG}: 【防禦元素】 (狀態: %RESULTS:10%)
    CASE ELEM_SPEC
        PRINTFORML [{ARG:3}] 槽位 H{ARG}: 【特殊元素】 (狀態: %RESULTS:10%)
    CASEELSE
        PRINTFORML [{ARG:3}] 槽位 H{ARG}: [未知元素:{ARG:1}] (狀態: %RESULTS:10%)
ENDSELECT
RETURN

@BATTLE_UI_PRINT_TEMP_SLOT, ARG, ARG:1
; ARG=元素ID, ARG:1=選取狀態(0/1)
IF ARG == 0
    PRINTL [420] Temp: [空]
    RETURN
ENDIF

IF ARG:1 == 1
    RESULTS:11 = "已選取 [X]"
ELSE
    RESULTS:11 = "未選取 [ ]"
ENDIF

SELECTCASE ARG
    CASE ELEM_PHYS
        PRINTFORML [420] Temp: 【物理元素】 (狀態: %RESULTS:11%)
    CASE ELEM_MAG
        PRINTFORML [420] Temp: 【魔法元素】 (狀態: %RESULTS:11%)
    CASE ELEM_DEF
        PRINTFORML [420] Temp: 【防禦元素】 (狀態: %RESULTS:11%)
    CASE ELEM_SPEC
        PRINTFORML [420] Temp: 【特殊元素】 (狀態: %RESULTS:11%)
    CASEELSE
        PRINTFORML [420] Temp: [未知元素:{ARG}] (狀態: %RESULTS:11%)
ENDSELECT
RETURN

@BATTLE_UI_MAIN
$BATTLE_UI_MAIN_LOOP
DRAWLINE
PRINTFORML 【戰鬥】Turn {TFLAG:BATTLE_TURN}
PRINTFORML HP {BASE:MASTER:BTL_HP}/{BASE:MASTER:BTL_MAXHP} | EN {BASE:MASTER:BTL_EN}/{BASE:MASTER:BTL_MAXEN} | TempUsed {TFLAG:TEMP_USED_THIS_TURN}
DRAWLINE

PRINTL (技能映射提示區預留位置)
DRAWLINE

CALL BATTLE_UI_PRINT_HAND_SLOT, 0, TFLAG:HAND0, TFLAG:UI_HAND0_SEL, 410
CALL BATTLE_UI_PRINT_HAND_SLOT, 1, TFLAG:HAND1, TFLAG:UI_HAND1_SEL, 411
CALL BATTLE_UI_PRINT_HAND_SLOT, 2, TFLAG:HAND2, TFLAG:UI_HAND2_SEL, 412
CALL BATTLE_UI_PRINT_HAND_SLOT, 3, TFLAG:HAND3, TFLAG:UI_HAND3_SEL, 413
CALL BATTLE_UI_PRINT_TEMP_SLOT, TFLAG:TEMP_CARD, TFLAG:UI_TEMP_SEL

DRAWLINE
PRINTL [410] 切換 H0 選取  [411] 切換 H1 選取  [412] 切換 H2 選取  [413] 切換 H3 選取
PRINTL [420] 切換 Temp 選取
PRINTL [450] 執行暫存槽存/取 (每回合限1次)
PRINTL [430] 確認出招
PRINTL [0] 逃跑並返回基地

INPUT RESULT
IF RESULT == 410
    IF TFLAG:UI_HAND0_SEL == 0
        TFLAG:UI_HAND0_SEL = 1
    ELSE
        TFLAG:UI_HAND0_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 411
    IF TFLAG:UI_HAND1_SEL == 0
        TFLAG:UI_HAND1_SEL = 1
    ELSE
        TFLAG:UI_HAND1_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 412
    IF TFLAG:UI_HAND2_SEL == 0
        TFLAG:UI_HAND2_SEL = 1
    ELSE
        TFLAG:UI_HAND2_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 413
    IF TFLAG:UI_HAND3_SEL == 0
        TFLAG:UI_HAND3_SEL = 1
    ELSE
        TFLAG:UI_HAND3_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 420
    IF TFLAG:UI_TEMP_SEL == 0
        TFLAG:UI_TEMP_SEL = 1
    ELSE
        TFLAG:UI_TEMP_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 450
    IF TFLAG:TEMP_USED_THIS_TURN == 1
        PRINTL 本回合已操作過暫存槽。
        GOTO BATTLE_UI_MAIN_LOOP
    ENDIF

    LOCAL:40 = 0
    LOCAL:41 = -1

    IF TFLAG:HAND0 != 0 && TFLAG:UI_HAND0_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND0
    ENDIF
    IF TFLAG:HAND1 != 0 && TFLAG:UI_HAND1_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND1
    ENDIF
    IF TFLAG:HAND2 != 0 && TFLAG:UI_HAND2_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND2
    ENDIF
    IF TFLAG:HAND3 != 0 && TFLAG:UI_HAND3_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND3
    ENDIF

    IF LOCAL:40 != 1
        PRINTL 必須精確選取 1 個手牌元素才能進行暫存操作。
        GOTO BATTLE_UI_MAIN_LOOP
    ENDIF

    LOCAL:42 = TFLAG:(LOCAL:41)
    IF TFLAG:TEMP_CARD == 0
        TFLAG:TEMP_CARD = LOCAL:42
        TFLAG:(LOCAL:41) = 0
        PRINTL 已將選取手牌移入 Temp。
    ELSE
        LOCAL:43 = TFLAG:TEMP_CARD
        TFLAG:TEMP_CARD = LOCAL:42
        TFLAG:(LOCAL:41) = LOCAL:43
        PRINTL 已完成手牌與 Temp 的元素交換。
    ENDIF

    TFLAG:UI_HAND0_SEL = 0
    TFLAG:UI_HAND1_SEL = 0
    TFLAG:UI_HAND2_SEL = 0
    TFLAG:UI_HAND3_SEL = 0
    TFLAG:UI_TEMP_SEL = 0
    TFLAG:TEMP_USED_THIS_TURN = 1
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 430
    CALL BATTLE_PROCESS_ACTION
    IF RESULT == 0
        GOTO BATTLE_UI_MAIN_LOOP
    ELSEIF RESULT == 1
        RETURN
    ENDIF

    CALL BATTLE_ENEMY_TURN
    IF RESULT == 1
        RETURN
    ENDIF

    TFLAG:BATTLE_TURN += 1
    CALL BATTLE_DRAW_CARDS
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 0
    RETURN
ELSE
    GOTO BATTLE_UI_MAIN_LOOP
ENDIF


@BATTLE_CALC_BOOST, ARG:0, ARG:1, ARG:2, ARG:3
; 依選取元素數量計算當回合臨時百分比 Buff
TFLAG:TEMP_BUFF_PATK = ARG:0 * 10
TFLAG:TEMP_BUFF_MATK = ARG:1 * 10
TFLAG:TEMP_BUFF_PDEF = ARG:2 * 10
TFLAG:TEMP_BUFF_MDEF = ARG:3 * 10
RETURN

@BATTLE_MATCH_SKILL, ARG:0, ARG:1, ARG:2, ARG:3
; 以需求陣列比對 20000~20010，可達成則回傳技能 ID，否則回傳 0
FOR LOCAL, 20000, 20010
    LOCAL:10 = SKILL_REQ_PHYS:LOCAL + SKILL_REQ_MAG:LOCAL + SKILL_REQ_DEF:LOCAL + SKILL_REQ_SPEC:LOCAL
    IF LOCAL:10 > 0
        IF ARG:0 >= SKILL_REQ_PHYS:LOCAL && ARG:1 >= SKILL_REQ_MAG:LOCAL && ARG:2 >= SKILL_REQ_DEF:LOCAL && ARG:3 >= SKILL_REQ_SPEC:LOCAL
            RETURN LOCAL
        ENDIF
    ENDIF
NEXT
RETURN 0

@BATTLE_PROCESS_ACTION
; 被選取元素計數：物理、魔法、防禦、特殊、總數
LOCAL:50 = 0
LOCAL:51 = 0
LOCAL:52 = 0
LOCAL:53 = 0
LOCAL:54 = 0

; H0
IF TFLAG:UI_HAND0_SEL == 1 && TFLAG:HAND0 != 0
    LOCAL:54 += 1
    SELECTCASE TFLAG:HAND0
        CASE ELEM_PHYS
            LOCAL:50 += 1
        CASE ELEM_MAG
            LOCAL:51 += 1
        CASE ELEM_DEF
            LOCAL:52 += 1
        CASE ELEM_SPEC
            LOCAL:53 += 1
    ENDSELECT
ENDIF

; H1
IF TFLAG:UI_HAND1_SEL == 1 && TFLAG:HAND1 != 0
    LOCAL:54 += 1
    SELECTCASE TFLAG:HAND1
        CASE ELEM_PHYS
            LOCAL:50 += 1
        CASE ELEM_MAG
            LOCAL:51 += 1
        CASE ELEM_DEF
            LOCAL:52 += 1
        CASE ELEM_SPEC
            LOCAL:53 += 1
    ENDSELECT
ENDIF

; H2
IF TFLAG:UI_HAND2_SEL == 1 && TFLAG:HAND2 != 0
    LOCAL:54 += 1
    SELECTCASE TFLAG:HAND2
        CASE ELEM_PHYS
            LOCAL:50 += 1
        CASE ELEM_MAG
            LOCAL:51 += 1
        CASE ELEM_DEF
            LOCAL:52 += 1
        CASE ELEM_SPEC
            LOCAL:53 += 1
    ENDSELECT
ENDIF

; H3
IF TFLAG:UI_HAND3_SEL == 1 && TFLAG:HAND3 != 0
    LOCAL:54 += 1
    SELECTCASE TFLAG:HAND3
        CASE ELEM_PHYS
            LOCAL:50 += 1
        CASE ELEM_MAG
            LOCAL:51 += 1
        CASE ELEM_DEF
            LOCAL:52 += 1
        CASE ELEM_SPEC
            LOCAL:53 += 1
    ENDSELECT
ENDIF

; Temp
IF TFLAG:UI_TEMP_SEL == 1 && TFLAG:TEMP_CARD != 0
    LOCAL:54 += 1
    SELECTCASE TFLAG:TEMP_CARD
        CASE ELEM_PHYS
            LOCAL:50 += 1
        CASE ELEM_MAG
            LOCAL:51 += 1
        CASE ELEM_DEF
            LOCAL:52 += 1
        CASE ELEM_SPEC
            LOCAL:53 += 1
    ENDSELECT
ENDIF

IF LOCAL:54 == 0
    PRINTW 請至少選取一個元素來發動攻擊！
    RETURN 0
ENDIF

CALL BATTLE_CALC_BOOST, LOCAL:50, LOCAL:51, LOCAL:52, LOCAL:53
CALL BATTLE_MATCH_SKILL, LOCAL:50, LOCAL:51, LOCAL:52, LOCAL:53
LOCAL:60 = RESULT

IF LOCAL:60 == 0
    PRINTL 【元素共鳴】未觸發特殊技能。發動基礎攻擊！
ELSE
    PRINTFORML 【元素共鳴】條件達成！發動技能 ID：{LOCAL:60}！
ENDIF
PRINTFORML (臨時 Buff) PATK+{TFLAG:TEMP_BUFF_PATK}％ / MATK+{TFLAG:TEMP_BUFF_MATK}％ / PDEF+{TFLAG:TEMP_BUFF_PDEF}％ / MDEF+{TFLAG:TEMP_BUFF_MDEF}％

CALL BATTLE_CALC_DAMAGE, LOCAL:60
LOCAL:70 = RESULT

; 消耗被選取元素
IF TFLAG:UI_HAND0_SEL == 1
    TFLAG:HAND0 = 0
ENDIF
IF TFLAG:UI_HAND1_SEL == 1
    TFLAG:HAND1 = 0
ENDIF
IF TFLAG:UI_HAND2_SEL == 1
    TFLAG:HAND2 = 0
ENDIF
IF TFLAG:UI_HAND3_SEL == 1
    TFLAG:HAND3 = 0
ENDIF
IF TFLAG:UI_TEMP_SEL == 1
    TFLAG:TEMP_CARD = 0
ENDIF

IF LOCAL:70 == 1
    RETURN 1
ENDIF

RETURN 2


@BATTLE_CALC_DAMAGE, ARG
; ARG = 技能 ID（0 代表普攻）
LOCAL:0 = TFLAG:BATTLE_TARGET
IF LOCAL:0 < 0 || LOCAL:0 >= CHARANUM
    PRINTL 目標不存在，無法進行傷害結算。
    RETURN 1
ENDIF

LOCAL:1 = BASE:MASTER:BTL_PATK
LOCAL:2 = TFLAG:TEMP_BUFF_PATK
LOCAL:3 = 0
IF ARG > 0
    LOCAL:3 = 10 + (ARG - 20000) * 5
ENDIF
LOCAL:4 = BASE:(LOCAL:0):BTL_PDEF
LOCAL:5 = LOCAL:1 * (100 + LOCAL:2) / 100
LOCAL:6 = LOCAL:5 + LOCAL:3 - LOCAL:4
IF LOCAL:6 < 0
    LOCAL:6 = 0
ENDIF

BASE:(LOCAL:0):BTL_HP -= LOCAL:6
IF BASE:(LOCAL:0):BTL_HP < 0
    BASE:(LOCAL:0):BTL_HP = 0
ENDIF

PRINTFORML 對木人樁造成了 {LOCAL:6} 點傷害！(剩餘 HP: {BASE:(LOCAL:0):BTL_HP}/{BASE:(LOCAL:0):BTL_MAXHP})

IF BASE:(LOCAL:0):BTL_HP <= 0
    PRINTL 木人樁被擊破！戰鬥勝利！
    DELCHARA LOCAL:0
    TFLAG:BATTLE_TARGET = -1
    RETURN 1
ENDIF
RETURN 0


@BATTLE_ENEMY_TURN
LOCAL:0 = TFLAG:BATTLE_TARGET
IF LOCAL:0 < 0 || LOCAL:0 >= CHARANUM
    RETURN 1
ENDIF
IF BASE:(LOCAL:0):BTL_HP <= 0
    RETURN 1
ENDIF

LOCAL:1 = 0
FOR LOCAL, 0, 4
    LOCAL:2 = PARTY_MEMBERS:LOCAL
    IF LOCAL:2 != -1 && BASE:(LOCAL:2):BTL_HP > 0
        LOCAL:(10 + LOCAL:1) = LOCAL:2
        LOCAL:1 += 1
    ENDIF
NEXT

IF LOCAL:1 <= 0
    RETURN 1
ENDIF

LOCAL:3 = RAND:(LOCAL:1)
LOCAL:2 = LOCAL:(10 + LOCAL:3)
DRAWLINE
PRINTFORML 【敵方回合】 %CALLNAME:LOCAL:0% 發動了攻擊！
LOCAL:4 = BASE:(LOCAL:0):BTL_PATK - BASE:(LOCAL:2):BTL_PDEF
IF LOCAL:4 < 0
    LOCAL:4 = 0
ENDIF

BASE:(LOCAL:2):BTL_HP -= LOCAL:4
IF BASE:(LOCAL:2):BTL_HP < 0
    BASE:(LOCAL:2):BTL_HP = 0
ENDIF

PRINTFORML 對 [%CALLNAME:LOCAL:2%] 造成了 {LOCAL:4} 點傷害！ (剩餘 HP: {BASE:(LOCAL:2):BTL_HP}/{BASE:(LOCAL:2):BTL_MAXHP})

IF BASE:MASTER:BTL_HP <= 0
    PRINTL 主角倒下了，戰鬥敗北。
    DELCHARA LOCAL:0
    TFLAG:BATTLE_TARGET = -1
    RETURN 1
ENDIF
RETURN 0
