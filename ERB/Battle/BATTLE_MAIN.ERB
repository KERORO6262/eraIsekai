@INIT_PARTY_STATE
IF PARTY_MEMBERS:0 != MASTER
    PARTY_MEMBERS:0 = MASTER
ENDIF
PARTY_MEMBERS:1 = -1
PARTY_MEMBERS:2 = -1
PARTY_MEMBERS:3 = -1
RETURN

@BATTLE_PREPARATION
TFLAG:BATTLE_LOOT_MONEY = 0
TFLAG:BATTLE_LOOT_MAT = 0
$BATTLE_PREPARATION_TOP
DRAWLINE
PRINTL 【戰前準備：隊伍編組】
IF PARTY_MEMBERS:0 == MASTER
    PRINTL [100] [X] 取消出戰：MASTER (主角)
ELSE
    PRINTL [100] [ ] 選擇出戰：MASTER (主角)
ENDIF
PRINTL [101] [ ] 隊友槽位 1（未實裝）
PRINTL [102] [ ] 隊友槽位 2（未實裝）
PRINTL [103] [ ] 隊友槽位 3（未實裝）
DRAWLINE
PRINTL [1] 確認出戰 (打木人樁)
PRINTL [0] 返回基地
INPUT RESULT

IF RESULT == 100
    IF PARTY_MEMBERS:0 == MASTER
        PARTY_MEMBERS:0 = -1
    ELSE
        PARTY_MEMBERS:0 = MASTER
    ENDIF
    GOTO BATTLE_PREPARATION_TOP
ENDIF
IF RESULT == 1
    LOCAL:20 = 0
    FOR LOCAL, 0, 3
        IF PARTY_MEMBERS:LOCAL != -1
            LOCAL:20 += 1
        ENDIF
    NEXT
    IF LOCAL:20 <= 0
        PRINTL 必須至少安排一名角色出戰！
        GOTO BATTLE_PREPARATION_TOP
    ENDIF

    CALL GENERATE_DUMMY_ENEMY
    CALL BATTLE_ENTER
    RETURN RESULT
ENDIF
IF RESULT == 0
    RETURN 0
ENDIF
PRINTL 請輸入 100、1 或 0。
GOTO BATTLE_PREPARATION_TOP

@BATTLE_ENTER
CALL INIT_MASTER_STATS

TFLAG:BATTLE_TURN = 1
TFLAG:BATTLE_LOOT_MONEY = 0
TFLAG:BATTLE_LOOT_MAT = 0
TFLAG:HAND0 = 0
TFLAG:HAND1 = 0
TFLAG:HAND2 = 0
TFLAG:HAND3 = 0
TFLAG:TEMP_CARD = 0
TFLAG:AUTO_TURNS_LEFT = 0
TFLAG:AUTO_STRATEGY = 0

CALL BATTLE_DRAW_CARDS
CALL BATTLE_UI_MAIN
RETURN RESULT

@GENERATE_DUMMY_ENEMY
ADDVOIDCHARA
TARGET = CHARANUM - 1
TFLAG:BATTLE_TARGET = TARGET
CALLNAME:TARGET = "木人樁"
BASE:TARGET:BTL_MAXHP = 500
BASE:TARGET:BTL_HP = 500
BASE:TARGET:BTL_PATK = 10
BASE:TARGET:BTL_MATK = 0
BASE:TARGET:BTL_PDEF = 0
BASE:TARGET:BTL_MDEF = 0
RETURN

@BATTLE_DRAW_CARDS
FOR LOCAL, HAND0, HAND3 + 1
    IF TFLAG:LOCAL == 0
        ; 1=物理, 2=魔法, 3=防禦, 4=特殊
        TFLAG:LOCAL = 1 + RAND:4
    ENDIF
NEXT

TFLAG:TEMP_USED_THIS_TURN = 0
TFLAG:UI_HAND0_SEL = 0
TFLAG:UI_HAND1_SEL = 0
TFLAG:UI_HAND2_SEL = 0
TFLAG:UI_HAND3_SEL = 0
TFLAG:UI_TEMP_SEL = 0
TFLAG:TEMP_BUFF_PATK = 0
TFLAG:TEMP_BUFF_MATK = 0
TFLAG:TEMP_BUFF_PDEF = 0
TFLAG:TEMP_BUFF_MDEF = 0
RETURN

@BATTLE_UI_PRINT_HAND_SLOT, ARG, ARG:1, ARG:2, ARG:3
; ARG=手牌索引(0~3), ARG:1=元素ID, ARG:2=選取狀態(0/1), ARG:3=指令編號(410~413)
IF ARG:1 == 0
    PRINTFORML [{ARG:3}] 槽位 H{ARG}: [空]
    RETURN
ENDIF

IF ARG:2 == 1
    RESULTS:10 = "已選取 [X]"
ELSE
    RESULTS:10 = "未選取 [ ]"
ENDIF

SELECTCASE ARG:1
    CASE ELEM_PHYS
        PRINTFORML [{ARG:3}] 槽位 H{ARG}: 【物理元素】 (狀態: %RESULTS:10%)
    CASE ELEM_MAG
        PRINTFORML [{ARG:3}] 槽位 H{ARG}: 【魔法元素】 (狀態: %RESULTS:10%)
    CASE ELEM_DEF
        PRINTFORML [{ARG:3}] 槽位 H{ARG}: 【防禦元素】 (狀態: %RESULTS:10%)
    CASE ELEM_SPEC
        PRINTFORML [{ARG:3}] 槽位 H{ARG}: 【特殊元素】 (狀態: %RESULTS:10%)
    CASEELSE
        PRINTFORML [{ARG:3}] 槽位 H{ARG}: [未知元素:{ARG:1}] (狀態: %RESULTS:10%)
ENDSELECT
RETURN

@BATTLE_UI_PRINT_TEMP_SLOT, ARG, ARG:1
; ARG=元素ID, ARG:1=選取狀態(0/1)
IF ARG == 0
    PRINTL [420] Temp: [空]
    RETURN
ENDIF

IF ARG:1 == 1
    RESULTS:11 = "已選取 [X]"
ELSE
    RESULTS:11 = "未選取 [ ]"
ENDIF

SELECTCASE ARG
    CASE ELEM_PHYS
        PRINTFORML [420] Temp: 【物理元素】 (狀態: %RESULTS:11%)
    CASE ELEM_MAG
        PRINTFORML [420] Temp: 【魔法元素】 (狀態: %RESULTS:11%)
    CASE ELEM_DEF
        PRINTFORML [420] Temp: 【防禦元素】 (狀態: %RESULTS:11%)
    CASE ELEM_SPEC
        PRINTFORML [420] Temp: 【特殊元素】 (狀態: %RESULTS:11%)
    CASEELSE
        PRINTFORML [420] Temp: [未知元素:{ARG}] (狀態: %RESULTS:11%)
ENDSELECT
RETURN

@BATTLE_UI_MAIN
$BATTLE_UI_MAIN_LOOP
DRAWLINE
PRINTFORML 【戰鬥】Turn {TFLAG:BATTLE_TURN}
PRINTFORML HP {BASE:MASTER:BTL_HP}/{BASE:MASTER:BTL_MAXHP} | EN {BASE:MASTER:BTL_EN}/{BASE:MASTER:BTL_MAXEN} | TempUsed {TFLAG:TEMP_USED_THIS_TURN}
IF TFLAG:AUTO_TURNS_LEFT > 0
    PRINTFORML 【自動戰鬥中... 剩餘 {TFLAG:AUTO_TURNS_LEFT} 回合】
ENDIF
DRAWLINE

PRINTL (技能映射提示區預留位置)
DRAWLINE

CALL BATTLE_UI_PRINT_HAND_SLOT, 0, TFLAG:HAND0, TFLAG:UI_HAND0_SEL, 410
CALL BATTLE_UI_PRINT_HAND_SLOT, 1, TFLAG:HAND1, TFLAG:UI_HAND1_SEL, 411
CALL BATTLE_UI_PRINT_HAND_SLOT, 2, TFLAG:HAND2, TFLAG:UI_HAND2_SEL, 412
CALL BATTLE_UI_PRINT_HAND_SLOT, 3, TFLAG:HAND3, TFLAG:UI_HAND3_SEL, 413
CALL BATTLE_UI_PRINT_TEMP_SLOT, TFLAG:TEMP_CARD, TFLAG:UI_TEMP_SEL

DRAWLINE
PRINTL [410] 切換 H0 選取  [411] 切換 H1 選取  [412] 切換 H2 選取  [413] 切換 H3 選取
PRINTL [420] 切換 Temp 選取
PRINTL [450] 執行暫存槽存/取 (每回合限1次)
PRINTL [430] 確認出招
CALL BATTLE_AUTO_PRINT_STRATEGY_OPTION, 531, 1
CALL BATTLE_AUTO_PRINT_STRATEGY_OPTION, 532, 2
IF TFLAG:AUTO_TURNS_LEFT > 0
    PRINTL [500] 停止自動戰鬥
ELSE
    PRINTL [505] 自動戰鬥 (5回合)  [510] 自動戰鬥 (10回合)  [520] 自動戰鬥 (20回合)
ENDIF
PRINTL [999] 開發者選項 (Debug)
PRINTL [0] 逃跑並返回基地

IF TFLAG:AUTO_TURNS_LEFT > 0
    TWAIT 600, 1
    RESULT = 430
    CALL BATTLE_AUTO_PROCESS
ELSE
    INPUT RESULT
ENDIF
IF RESULT == 410
    IF TFLAG:UI_HAND0_SEL == 0
        TFLAG:UI_HAND0_SEL = 1
    ELSE
        TFLAG:UI_HAND0_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 411
    IF TFLAG:UI_HAND1_SEL == 0
        TFLAG:UI_HAND1_SEL = 1
    ELSE
        TFLAG:UI_HAND1_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 412
    IF TFLAG:UI_HAND2_SEL == 0
        TFLAG:UI_HAND2_SEL = 1
    ELSE
        TFLAG:UI_HAND2_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 413
    IF TFLAG:UI_HAND3_SEL == 0
        TFLAG:UI_HAND3_SEL = 1
    ELSE
        TFLAG:UI_HAND3_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 420
    IF TFLAG:UI_TEMP_SEL == 0
        TFLAG:UI_TEMP_SEL = 1
    ELSE
        TFLAG:UI_TEMP_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 450
    IF TFLAG:TEMP_USED_THIS_TURN == 1
        PRINTL 本回合已操作過暫存槽。
        GOTO BATTLE_UI_MAIN_LOOP
    ENDIF

    LOCAL:40 = 0
    LOCAL:41 = -1

    IF TFLAG:HAND0 != 0 && TFLAG:UI_HAND0_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND0
    ENDIF
    IF TFLAG:HAND1 != 0 && TFLAG:UI_HAND1_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND1
    ENDIF
    IF TFLAG:HAND2 != 0 && TFLAG:UI_HAND2_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND2
    ENDIF
    IF TFLAG:HAND3 != 0 && TFLAG:UI_HAND3_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND3
    ENDIF

    IF LOCAL:40 != 1
        PRINTL 必須精確選取 1 個手牌元素才能進行暫存操作。
        GOTO BATTLE_UI_MAIN_LOOP
    ENDIF

    LOCAL:42 = TFLAG:(LOCAL:41)
    IF TFLAG:TEMP_CARD == 0
        TFLAG:TEMP_CARD = LOCAL:42
        TFLAG:(LOCAL:41) = 0
        PRINTL 已將選取手牌移入 Temp。
    ELSE
        LOCAL:43 = TFLAG:TEMP_CARD
        TFLAG:TEMP_CARD = LOCAL:42
        TFLAG:(LOCAL:41) = LOCAL:43
        PRINTL 已完成手牌與 Temp 的元素交換。
    ENDIF

    TFLAG:UI_HAND0_SEL = 0
    TFLAG:UI_HAND1_SEL = 0
    TFLAG:UI_HAND2_SEL = 0
    TFLAG:UI_HAND3_SEL = 0
    TFLAG:UI_TEMP_SEL = 0
    TFLAG:TEMP_USED_THIS_TURN = 1
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 500
    TFLAG:AUTO_TURNS_LEFT = 0
    PRINTL 已停止自動戰鬥。
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 531
    TFLAG:AUTO_STRATEGY = 1
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 532
    TFLAG:AUTO_STRATEGY = 2
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 505 || RESULT == 510 || RESULT == 520
    IF TFLAG:AUTO_STRATEGY == 0
        PRINTFORMW 請先選擇一項自動戰鬥策略！
        GOTO BATTLE_UI_MAIN_LOOP
    ENDIF
    SELECTCASE RESULT
        CASE 505
            TFLAG:AUTO_TURNS_LEFT = 5
        CASE 510
            TFLAG:AUTO_TURNS_LEFT = 10
        CASE 520
            TFLAG:AUTO_TURNS_LEFT = 20
    ENDSELECT
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 430
    CALL BATTLE_PROCESS_ACTION
    IF RESULT == 0
        GOTO BATTLE_UI_MAIN_LOOP
    ELSEIF RESULT == 1
        RETURN 1
    ENDIF

    CALL BATTLE_ENEMY_TURN
    IF RESULT == 1
        RETURN 0
    ENDIF

    IF TFLAG:AUTO_TURNS_LEFT > 0
        TWAIT 1200, 1
        TFLAG:AUTO_TURNS_LEFT -= 1
        IF TFLAG:AUTO_TURNS_LEFT <= 0
            TFLAG:AUTO_TURNS_LEFT = 0
            PRINTFORMW 自動戰鬥已結束，恢復手動操作。
        ENDIF
    ENDIF

    TFLAG:BATTLE_TURN += 1
    CALL BATTLE_DRAW_CARDS
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 999
    CALL DEBUG_BATTLE_MENU
    IF RESULT == 1
        CALL BATTLE_RESOLVE_VICTORY
        RETURN 1
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 0
    RETURN 0
ELSE
    GOTO BATTLE_UI_MAIN_LOOP
ENDIF


@BATTLE_CALC_BOOST, ARG:0, ARG:1, ARG:2, ARG:3
; 依選取元素數量計算當回合臨時百分比 Buff
TFLAG:TEMP_BUFF_PATK = ARG:0 * 10
TFLAG:TEMP_BUFF_MATK = ARG:1 * 10
TFLAG:TEMP_BUFF_PDEF = ARG:2 * 10
TFLAG:TEMP_BUFF_MDEF = ARG:3 * 10
RETURN

@BATTLE_MATCH_SKILL, ARG:0, ARG:1, ARG:2, ARG:3
; 以需求陣列比對 20000~20010，可達成則回傳技能 ID，否則回傳 0
FOR LOCAL, 20000, 20010
    LOCAL:10 = SKILL_REQ_PHYS:LOCAL + SKILL_REQ_MAG:LOCAL + SKILL_REQ_DEF:LOCAL + SKILL_REQ_SPEC:LOCAL
    IF LOCAL:10 > 0
        IF ARG:0 >= SKILL_REQ_PHYS:LOCAL && ARG:1 >= SKILL_REQ_MAG:LOCAL && ARG:2 >= SKILL_REQ_DEF:LOCAL && ARG:3 >= SKILL_REQ_SPEC:LOCAL
            RETURN LOCAL
        ENDIF
    ENDIF
NEXT
RETURN 0

@BATTLE_CLEAR_SELECTIONS
TFLAG:UI_HAND0_SEL = 0
TFLAG:UI_HAND1_SEL = 0
TFLAG:UI_HAND2_SEL = 0
TFLAG:UI_HAND3_SEL = 0
TFLAG:UI_TEMP_SEL = 0
RETURN

@BATTLE_GET_AUTO_STRATEGY_NAME, ARG
SELECTCASE ARG
    CASE 1
        RESULTS:20 = "激進輸出"
    CASE 2
        RESULTS:20 = "保守防禦"
    CASEELSE
        RESULTS:20 = "未設定"
ENDSELECT
RETURN

@BATTLE_AUTO_PRINT_STRATEGY_OPTION, ARG, ARG:1
CALL BATTLE_GET_AUTO_STRATEGY_NAME, ARG:1
IF TFLAG:AUTO_STRATEGY == ARG:1
    PRINTFORML [{ARG}] 策略設定：[X] %RESULTS:20%
ELSE
    PRINTFORML [{ARG}] 策略設定：[ ] %RESULTS:20%
ENDIF
RETURN

@BATTLE_APPEND_AUTO_ELEM_NAME, ARG
IF ARG == 0
    RETURN
ENDIF
IF RESULTS:21 != ""
    RESULTS:21 += "、"
ENDIF
SELECTCASE ARG
    CASE ELEM_PHYS
        RESULTS:21 += "物理"
    CASE ELEM_MAG
        RESULTS:21 += "魔法"
    CASE ELEM_DEF
        RESULTS:21 += "防禦"
    CASE ELEM_SPEC
        RESULTS:21 += "特殊"
    CASEELSE
        RESULTS:21 += "未知"
ENDSELECT
RETURN

@BATTLE_AUTO_SET_HAND_SELECTION, ARG, ARG:1
SELECTCASE ARG
    CASE 0
        TFLAG:UI_HAND0_SEL = ARG:1
    CASE 1
        TFLAG:UI_HAND1_SEL = ARG:1
    CASE 2
        TFLAG:UI_HAND2_SEL = ARG:1
    CASE 3
        TFLAG:UI_HAND3_SEL = ARG:1
ENDSELECT
RETURN

@BATTLE_AUTO_PROCESS
CALL BATTLE_CLEAR_SELECTIONS
CALL BATTLE_GET_AUTO_STRATEGY_NAME, TFLAG:AUTO_STRATEGY
RESULTS:21 = ""
LOCAL:100 = PARTY_MEMBERS:0
IF LOCAL:100 == -1
    LOCAL:100 = MASTER
ENDIF
LOCAL:1 = BASE:(LOCAL:100):BTL_HP * 100
IF BASE:(LOCAL:100):BTL_MAXHP > 0
    LOCAL:1 /= BASE:(LOCAL:100):BTL_MAXHP
ELSE
    LOCAL:1 = 100
ENDIF
LOCAL:2 = 0
LOCAL:3 = 0
IF TFLAG:AUTO_STRATEGY == 1
    LOCAL:2 = 1
ELSEIF TFLAG:AUTO_STRATEGY == 2
    LOCAL:3 = 1
ENDIF
LOCAL:4 = 0
FOR LOCAL, 0, 4
    LOCAL:10 = TFLAG:(HAND0 + LOCAL)
    LOCAL:11 = 0
    IF TFLAG:AUTO_STRATEGY == 1
        IF LOCAL:10 == ELEM_PHYS || LOCAL:10 == ELEM_MAG
            LOCAL:11 = 1
        ENDIF
    ELSEIF TFLAG:AUTO_STRATEGY == 2
        IF LOCAL:10 == ELEM_DEF || LOCAL:10 == ELEM_SPEC
            LOCAL:11 = 1
        ENDIF
        IF LOCAL:1 < 50 && LOCAL:10 == ELEM_MAG
            LOCAL:11 = 1
        ENDIF
    ENDIF
    IF LOCAL:11 == 1
        CALL BATTLE_AUTO_SET_HAND_SELECTION, LOCAL, 1
        CALL BATTLE_APPEND_AUTO_ELEM_NAME, LOCAL:10
        LOCAL:4 += 1
    ENDIF
NEXT
IF TFLAG:TEMP_CARD != 0
    LOCAL:12 = 0
    IF TFLAG:AUTO_STRATEGY == 1
        IF TFLAG:TEMP_CARD == ELEM_PHYS || TFLAG:TEMP_CARD == ELEM_MAG
            LOCAL:12 = 1
        ENDIF
    ELSEIF TFLAG:AUTO_STRATEGY == 2
        IF TFLAG:TEMP_CARD == ELEM_DEF || TFLAG:TEMP_CARD == ELEM_SPEC
            LOCAL:12 = 1
        ENDIF
        IF LOCAL:1 < 50 && TFLAG:TEMP_CARD == ELEM_MAG
            LOCAL:12 = 1
        ENDIF
    ENDIF
    IF LOCAL:12 == 1
        TFLAG:UI_TEMP_SEL = 1
        CALL BATTLE_APPEND_AUTO_ELEM_NAME, TFLAG:TEMP_CARD
        LOCAL:4 += 1
    ENDIF
ENDIF
IF TFLAG:TEMP_USED_THIS_TURN == 0 && TFLAG:TEMP_CARD != 0
    IF TFLAG:AUTO_STRATEGY == 1 && (TFLAG:TEMP_CARD == ELEM_PHYS || TFLAG:TEMP_CARD == ELEM_MAG)
        FOR LOCAL, 0, 4
            LOCAL:20 = TFLAG:(HAND0 + LOCAL)
            IF LOCAL:20 == ELEM_DEF || LOCAL:20 == ELEM_SPEC
                CALL BATTLE_CLEAR_SELECTIONS
                RESULTS:21 = ""
                TFLAG:(HAND0 + LOCAL) = TFLAG:TEMP_CARD
                TFLAG:TEMP_CARD = LOCAL:20
                TFLAG:TEMP_USED_THIS_TURN = 1
                BREAK
            ENDIF
        NEXT
    ELSEIF TFLAG:AUTO_STRATEGY == 2 && (TFLAG:TEMP_CARD == ELEM_DEF || TFLAG:TEMP_CARD == ELEM_SPEC)
        FOR LOCAL, 0, 4
            LOCAL:20 = TFLAG:(HAND0 + LOCAL)
            IF LOCAL:20 == ELEM_PHYS || (LOCAL:20 == ELEM_MAG && LOCAL:1 >= 50)
                CALL BATTLE_CLEAR_SELECTIONS
                RESULTS:21 = ""
                TFLAG:(HAND0 + LOCAL) = TFLAG:TEMP_CARD
                TFLAG:TEMP_CARD = LOCAL:20
                TFLAG:TEMP_USED_THIS_TURN = 1
                BREAK
            ENDIF
        NEXT
    ENDIF
ENDIF
IF RESULTS:21 == ""
    FOR LOCAL, 0, 4
        LOCAL:30 = TFLAG:(HAND0 + LOCAL)
        LOCAL:31 = 0
        IF TFLAG:AUTO_STRATEGY == 1
            IF LOCAL:30 == ELEM_PHYS || LOCAL:30 == ELEM_MAG
                LOCAL:31 = 1
            ENDIF
        ELSEIF TFLAG:AUTO_STRATEGY == 2
            IF LOCAL:30 == ELEM_DEF || LOCAL:30 == ELEM_SPEC
                LOCAL:31 = 1
            ENDIF
            IF LOCAL:1 < 50 && LOCAL:30 == ELEM_MAG
                LOCAL:31 = 1
            ENDIF
        ENDIF
        IF LOCAL:31 == 1
            CALL BATTLE_AUTO_SET_HAND_SELECTION, LOCAL, 1
            CALL BATTLE_APPEND_AUTO_ELEM_NAME, LOCAL:30
        ENDIF
    NEXT
ENDIF
IF RESULTS:21 == ""
    IF TFLAG:HAND0 != 0
        CALL BATTLE_AUTO_SET_HAND_SELECTION, 0, 1
        CALL BATTLE_APPEND_AUTO_ELEM_NAME, TFLAG:HAND0
    ELSE
        RESULTS:21 = "無可用元素"
    ENDIF
ENDIF
PRINTFORML 【自動戰報】第 {TFLAG:BATTLE_TURN} 回合：AI 採取 [%RESULTS:20%] 策略，選取了 %RESULTS:21%...
RETURN

@BATTLE_PROCESS_ACTION
LOCAL:50 = 0
LOCAL:51 = 0
LOCAL:52 = 0
LOCAL:53 = 0
LOCAL:54 = 0

IF TFLAG:UI_HAND0_SEL == 1 && TFLAG:HAND0 != 0
    LOCAL:54 += 1
    SELECTCASE TFLAG:HAND0
        CASE ELEM_PHYS
            LOCAL:50 += 1
        CASE ELEM_MAG
            LOCAL:51 += 1
        CASE ELEM_DEF
            LOCAL:52 += 1
        CASE ELEM_SPEC
            LOCAL:53 += 1
    ENDSELECT
ENDIF
IF TFLAG:UI_HAND1_SEL == 1 && TFLAG:HAND1 != 0
    LOCAL:54 += 1
    SELECTCASE TFLAG:HAND1
        CASE ELEM_PHYS
            LOCAL:50 += 1
        CASE ELEM_MAG
            LOCAL:51 += 1
        CASE ELEM_DEF
            LOCAL:52 += 1
        CASE ELEM_SPEC
            LOCAL:53 += 1
    ENDSELECT
ENDIF
IF TFLAG:UI_HAND2_SEL == 1 && TFLAG:HAND2 != 0
    LOCAL:54 += 1
    SELECTCASE TFLAG:HAND2
        CASE ELEM_PHYS
            LOCAL:50 += 1
        CASE ELEM_MAG
            LOCAL:51 += 1
        CASE ELEM_DEF
            LOCAL:52 += 1
        CASE ELEM_SPEC
            LOCAL:53 += 1
    ENDSELECT
ENDIF
IF TFLAG:UI_HAND3_SEL == 1 && TFLAG:HAND3 != 0
    LOCAL:54 += 1
    SELECTCASE TFLAG:HAND3
        CASE ELEM_PHYS
            LOCAL:50 += 1
        CASE ELEM_MAG
            LOCAL:51 += 1
        CASE ELEM_DEF
            LOCAL:52 += 1
        CASE ELEM_SPEC
            LOCAL:53 += 1
    ENDSELECT
ENDIF
IF TFLAG:UI_TEMP_SEL == 1 && TFLAG:TEMP_CARD != 0
    LOCAL:54 += 1
    SELECTCASE TFLAG:TEMP_CARD
        CASE ELEM_PHYS
            LOCAL:50 += 1
        CASE ELEM_MAG
            LOCAL:51 += 1
        CASE ELEM_DEF
            LOCAL:52 += 1
        CASE ELEM_SPEC
            LOCAL:53 += 1
    ENDSELECT
ENDIF

IF LOCAL:54 == 0
    PRINTW 請至少選取一個元素來發動攻擊！
    RETURN 0
ENDIF

CALL BATTLE_CALC_BOOST, LOCAL:50, LOCAL:51, LOCAL:52, LOCAL:53
CALL BATTLE_MATCH_SKILL, LOCAL:50, LOCAL:51, LOCAL:52, LOCAL:53
LOCAL:60 = RESULT

IF LOCAL:60 == 0
    PRINTL 【元素共鳴】未觸發特殊技能。發動基礎攻擊！
ELSE
    PRINTFORML 【元素共鳴】條件達成！發動技能 ID：{LOCAL:60}！
ENDIF
PRINTFORML (臨時 Buff) PATK+{TFLAG:TEMP_BUFF_PATK}％ / MATK+{TFLAG:TEMP_BUFF_MATK}％ / PDEF+{TFLAG:TEMP_BUFF_PDEF}％ / MDEF+{TFLAG:TEMP_BUFF_MDEF}％

CALL BATTLE_CALC_DAMAGE, LOCAL:60
LOCAL:70 = RESULT

IF TFLAG:UI_HAND0_SEL == 1
    TFLAG:HAND0 = 0
ENDIF
IF TFLAG:UI_HAND1_SEL == 1
    TFLAG:HAND1 = 0
ENDIF
IF TFLAG:UI_HAND2_SEL == 1
    TFLAG:HAND2 = 0
ENDIF
IF TFLAG:UI_HAND3_SEL == 1
    TFLAG:HAND3 = 0
ENDIF
IF TFLAG:UI_TEMP_SEL == 1
    TFLAG:TEMP_CARD = 0
ENDIF

IF LOCAL:70 == 1
    RETURN 1
ENDIF

RETURN 2

@BATTLE_RESOLVE_VICTORY
LOCAL:0 = TFLAG:BATTLE_TARGET
TFLAG:BATTLE_LOOT_MONEY = 100
TFLAG:BATTLE_LOOT_MAT = 20
PRINTL 木人樁被擊破！戰鬥勝利！
PRINTFORML 獲得掉落：金錢 {TFLAG:BATTLE_LOOT_MONEY} / 材料 {TFLAG:BATTLE_LOOT_MAT}
IF LOCAL:0 >= 0 && LOCAL:0 < CHARANUM
    DELCHARA LOCAL:0
ENDIF
TFLAG:BATTLE_TARGET = -1
WAIT
RETURN 1

@BATTLE_CALC_DAMAGE, ARG
; ARG = 技能 ID（0 代表普攻）
LOCAL:0 = TFLAG:BATTLE_TARGET
IF LOCAL:0 < 0 || LOCAL:0 >= CHARANUM
    PRINTL 目標不存在，無法進行結算。
    RETURN 1
ENDIF

SELECTCASE ARG
    CASE 20003
        LOCAL:1 = 20 + BASE:MASTER:BTL_MATK * (100 + TFLAG:TEMP_BUFF_MATK) / 200
        BASE:MASTER:BTL_HP += LOCAL:1
        IF BASE:MASTER:BTL_HP > BASE:MASTER:BTL_MAXHP
            BASE:MASTER:BTL_HP = BASE:MASTER:BTL_MAXHP
        ENDIF
        PRINTFORML 【治癒之風】恢復了 {LOCAL:1} 點 HP！(目前 HP: {BASE:MASTER:BTL_HP}/{BASE:MASTER:BTL_MAXHP})
        RETURN 0
    CASE 20004
        LOCAL:1 = 25 + TFLAG:TEMP_BUFF_PDEF
        TFLAG:TEMP_BUFF_PDEF += LOCAL:1
        PRINTFORML 【堅壁陣型】本回合額外提升 {LOCAL:1}％ 物理防禦！(目前 PDEF Buff: {TFLAG:TEMP_BUFF_PDEF}％)
        RETURN 0
    CASEELSE
        LOCAL:1 = BASE:MASTER:BTL_PATK
        LOCAL:2 = TFLAG:TEMP_BUFF_PATK
        LOCAL:3 = 0
        IF ARG > 0
            LOCAL:3 = 10 + (ARG - 20000) * 5
        ENDIF
        LOCAL:4 = BASE:(LOCAL:0):BTL_PDEF
        LOCAL:5 = LOCAL:1 * (100 + LOCAL:2) / 100
        LOCAL:6 = LOCAL:5 + LOCAL:3 - LOCAL:4
        IF LOCAL:6 < 0
            LOCAL:6 = 0
        ENDIF

        BASE:(LOCAL:0):BTL_HP -= LOCAL:6
        IF BASE:(LOCAL:0):BTL_HP < 0
            BASE:(LOCAL:0):BTL_HP = 0
        ENDIF

        PRINTFORML 對木人樁造成了 {LOCAL:6} 點傷害！(剩餘 HP: {BASE:(LOCAL:0):BTL_HP}/{BASE:(LOCAL:0):BTL_MAXHP})

        IF BASE:(LOCAL:0):BTL_HP <= 0
            CALL BATTLE_RESOLVE_VICTORY
            RETURN RESULT
        ENDIF
        RETURN 0
ENDSELECT


@BATTLE_ENEMY_TURN
LOCAL:5 = TFLAG:BATTLE_TARGET
IF LOCAL:5 < 0 || LOCAL:5 >= CHARANUM
    RETURN 1
ENDIF
IF BASE:(LOCAL:5):BTL_HP <= 0
    RETURN 1
ENDIF

LOCAL:1 = 0
FOR LOCAL, 0, 4
    LOCAL:2 = PARTY_MEMBERS:LOCAL
    IF LOCAL:2 != -1 && BASE:(LOCAL:2):BTL_HP > 0
        LOCAL:(10 + LOCAL:1) = LOCAL:2
        LOCAL:1 += 1
    ENDIF
NEXT

IF LOCAL:1 <= 0
    RETURN 1
ENDIF

LOCAL:3 = RAND:(LOCAL:1)
LOCAL:2 = LOCAL:(10 + LOCAL:3)
DRAWLINE
PRINTFORML 【敵方回合】 %CALLNAME:(LOCAL:5)% 發動了攻擊！
LOCAL:4 = BASE:(LOCAL:5):BTL_PATK * (100 - TFLAG:TEMP_BUFF_PDEF) / 100 - BASE:(LOCAL:2):BTL_PDEF
IF LOCAL:4 < 0
    LOCAL:4 = 0
ENDIF

BASE:(LOCAL:2):BTL_HP -= LOCAL:4
IF BASE:(LOCAL:2):BTL_HP < 0
    BASE:(LOCAL:2):BTL_HP = 0
ENDIF

PRINTFORML 對 [%CALLNAME:(LOCAL:2)%] 造成了 {LOCAL:4} 點傷害！ (剩餘 HP: {BASE:(LOCAL:2):BTL_HP}/{BASE:(LOCAL:2):BTL_MAXHP})

IF BASE:MASTER:BTL_HP <= 0
    PRINTL 主角倒下了，戰鬥敗北。
    WAIT
    DELCHARA LOCAL:5
    TFLAG:BATTLE_TARGET = -1
    RETURN 1
ENDIF
RETURN 0
