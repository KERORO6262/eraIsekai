; ==========================================
; ERA ISEKAI - Battle Module
; ==========================================

@BATTLE_INIT
; ===== 技能配方資料初始化（Shape 軸） =====
; 先清空本期使用區間，避免重複初始化時殘留舊值
FOR LOCAL, 20000, 20010
    SKILL_REQ_SHAPE_PHYS:LOCAL = 0
    SKILL_REQ_SHAPE_MAG:LOCAL = 0
    SKILL_REQ_SHAPE_DEF:LOCAL = 0
    SKILL_REQ_SHAPE_SPEC:LOCAL = 0
NEXT

; 20001 重力斬擊：2 物理 + 1 魔法
SKILL_REQ_SHAPE_PHYS:20001 = 2
SKILL_REQ_SHAPE_MAG:20001 = 1

; 20002 絕對防禦：3 防禦
SKILL_REQ_SHAPE_DEF:20002 = 3
RETURN

@BATTLE_SETTLEMENT_REPORT
IF RESULT == 1
    FLAG:RES_MONEY += TFLAG:BATTLE_LOOT_MONEY
    FLAG:RES_MATERIAL += TFLAG:BATTLE_LOOT_MAT
    PRINTFORML 【戰報摘要】戰鬥勝利！獲得了 {TFLAG:BATTLE_LOOT_MONEY} 金錢 與 {TFLAG:BATTLE_LOOT_MAT} 材料。經過了 {TFLAG:BATTLE_TURN} 回合。
ELSE
    PRINTL 【戰報摘要】隊伍撤退或戰敗。
ENDIF
TFLAG:BATTLE_LOOT_MONEY = 0
TFLAG:BATTLE_LOOT_MAT = 0
RETURN

@INIT_PARTY_STATE
IF PARTY_MEMBERS:0 != MASTER
    PARTY_MEMBERS:0 = MASTER
ENDIF
PARTY_MEMBERS:1 = -1
PARTY_MEMBERS:2 = -1
PARTY_MEMBERS:3 = -1
RETURN

@BATTLE_PREPARATION
TFLAG:BATTLE_LOOT_MONEY = 0
TFLAG:BATTLE_LOOT_MAT = 0
$BATTLE_PREPARATION_TOP
DRAWLINE
PRINTL 【戰前準備：隊伍編組】
IF PARTY_MEMBERS:0 == MASTER
    PRINTL [100] [X] 取消出戰：MASTER (主角)
ELSE
    PRINTL [100] [ ] 選擇出戰：MASTER (主角)
ENDIF
PRINTL [101] [ ] 隊友槽位 1（未實裝）
PRINTL [102] [ ] 隊友槽位 2（未實裝）
PRINTL [103] [ ] 隊友槽位 3（未實裝）
DRAWLINE
PRINTL [1] 確認出戰 (打木人樁)
PRINTL [0] 返回基地
INPUT RESULT

IF RESULT == 100
    IF PARTY_MEMBERS:0 == MASTER
        PARTY_MEMBERS:0 = -1
    ELSE
        PARTY_MEMBERS:0 = MASTER
    ENDIF
    GOTO BATTLE_PREPARATION_TOP
ENDIF
IF RESULT == 1
    LOCAL:20 = 0
    FOR LOCAL, 0, 3
        IF PARTY_MEMBERS:LOCAL != -1
            LOCAL:20 += 1
        ENDIF
    NEXT
    IF LOCAL:20 <= 0
        PRINTL 必須至少安排一名角色出戰！
        GOTO BATTLE_PREPARATION_TOP
    ENDIF

    CALL GENERATE_DUMMY_ENEMY
    CALL BATTLE_ENTER
    RETURN RESULT
ENDIF
IF RESULT == 0
    RETURN 0
ENDIF
PRINTL 請輸入 100、1 或 0。
GOTO BATTLE_PREPARATION_TOP

@BATTLE_ENTER
CALL INIT_MASTER_STATS

TFLAG:BATTLE_TURN = 1
TFLAG:BATTLE_LOOT_MONEY = 0
TFLAG:BATTLE_LOOT_MAT = 0
TFLAG:HAND0 = 0
TFLAG:HAND1 = 0
TFLAG:HAND2 = 0
TFLAG:HAND3 = 0
TFLAG:TEMP_CARD = 0

CALL BATTLE_DRAW_CARDS
CALL BATTLE_UI_MAIN
RETURN RESULT

@GENERATE_DUMMY_ENEMY
ADDVOIDCHARA
TARGET = CHARANUM - 1
TFLAG:BATTLE_TARGET = TARGET
CALLNAME:TARGET = "木人樁"
BASE:TARGET:BTL_MAXHP = 500
BASE:TARGET:BTL_HP = 500
BASE:TARGET:BTL_PATK = 10
BASE:TARGET:BTL_MATK = 0
BASE:TARGET:BTL_PDEF = 0
BASE:TARGET:BTL_MDEF = 0
RETURN

@BATTLE_DRAW_CARDS
FOR LOCAL, HAND0, HAND3 + 1
    IF TFLAG:LOCAL == 0
        ; 以十位/個位打包卡牌：ATTRIBUTE*10 + SHAPE（0 仍代表空槽）
        ; 安全規範：FOR LOCAL 迴圈內禁止寫入 LOCAL/LOCAL:0，避免破壞計數器造成疑似無限迴圈
        LOCAL:1 = 1 + RAND:4 ; Attribute：火/水/風/土
        LOCAL:2 = 1 + RAND:4 ; Shape：物理/魔法/防禦/特殊
        TFLAG:LOCAL = LOCAL:1 * CARD_PACK_BASE + LOCAL:2
    ENDIF
NEXT

TFLAG:TEMP_USED_THIS_TURN = 0
TFLAG:UI_HAND0_SEL = 0
TFLAG:UI_HAND1_SEL = 0
TFLAG:UI_HAND2_SEL = 0
TFLAG:UI_HAND3_SEL = 0
TFLAG:UI_TEMP_SEL = 0
TFLAG:TEMP_BUFF_PATK = 0
TFLAG:TEMP_BUFF_MATK = 0
TFLAG:TEMP_BUFF_PDEF = 0
TFLAG:TEMP_BUFF_MDEF = 0
RETURN

@BATTLE_UI_PRINT_HAND_SLOT, ARG, ARG:1, ARG:2, ARG:3
; ARG=手牌索引(0~3), ARG:1=卡牌打包值, ARG:2=選取狀態(0/1), ARG:3=指令編號(410~413)
IF ARG:1 == 0
    PRINTFORML [{ARG:3}] 槽位 H{ARG}: [空]
    RETURN
ENDIF

IF ARG:2 == 1
    RESULTS:10 = "已選取 [X]"
ELSE
    RESULTS:10 = "未選取 [ ]"
ENDIF

LOCAL:1 = ARG:1 / CARD_PACK_BASE
LOCAL:2 = ARG:1 - LOCAL:1 * CARD_PACK_BASE
RESULTS:20 = "?"
RESULTS:21 = "?"

SELECTCASE LOCAL:1
    CASE ATTR_FIRE
        RESULTS:20 = "火"
    CASE ATTR_WATER
        RESULTS:20 = "水"
    CASE ATTR_WIND
        RESULTS:20 = "風"
    CASE ATTR_EARTH
        RESULTS:20 = "土"
ENDSELECT
SELECTCASE LOCAL:2
    CASE SHAPE_PHYS
        RESULTS:21 = "物理"
    CASE SHAPE_MAG
        RESULTS:21 = "魔法"
    CASE SHAPE_DEF
        RESULTS:21 = "防禦"
    CASE SHAPE_SPEC
        RESULTS:21 = "特殊"
ENDSELECT

PRINTFORML [{ARG:3}] 槽位 H{ARG}: [%RESULTS:20%·%RESULTS:21%] (狀態: %RESULTS:10%)
RETURN

@BATTLE_UI_PRINT_TEMP_SLOT, ARG, ARG:1
; ARG=卡牌打包值, ARG:1=選取狀態(0/1)
IF ARG == 0
    PRINTL [420] Temp: [空]
    RETURN
ENDIF

IF ARG:1 == 1
    RESULTS:11 = "已選取 [X]"
ELSE
    RESULTS:11 = "未選取 [ ]"
ENDIF

LOCAL:1 = ARG / CARD_PACK_BASE
LOCAL:2 = ARG - LOCAL:1 * CARD_PACK_BASE
RESULTS:22 = "?"
RESULTS:23 = "?"

SELECTCASE LOCAL:1
    CASE ATTR_FIRE
        RESULTS:22 = "火"
    CASE ATTR_WATER
        RESULTS:22 = "水"
    CASE ATTR_WIND
        RESULTS:22 = "風"
    CASE ATTR_EARTH
        RESULTS:22 = "土"
ENDSELECT
SELECTCASE LOCAL:2
    CASE SHAPE_PHYS
        RESULTS:23 = "物理"
    CASE SHAPE_MAG
        RESULTS:23 = "魔法"
    CASE SHAPE_DEF
        RESULTS:23 = "防禦"
    CASE SHAPE_SPEC
        RESULTS:23 = "特殊"
ENDSELECT

PRINTFORML [420] Temp: [%RESULTS:22%·%RESULTS:23%] (狀態: %RESULTS:11%)
RETURN

@BATTLE_UI_MAIN
$BATTLE_UI_MAIN_LOOP
DRAWLINE
PRINTFORML 【戰鬥】Turn {TFLAG:BATTLE_TURN}
PRINTFORML HP {BASE:MASTER:BTL_HP}/{BASE:MASTER:BTL_MAXHP} | EN {BASE:MASTER:BTL_EN}/{BASE:MASTER:BTL_MAXEN} | TempUsed {TFLAG:TEMP_USED_THIS_TURN}
DRAWLINE

PRINTL (技能映射提示區預留位置)
DRAWLINE

CALL BATTLE_UI_PRINT_HAND_SLOT, 0, TFLAG:HAND0, TFLAG:UI_HAND0_SEL, 410
CALL BATTLE_UI_PRINT_HAND_SLOT, 1, TFLAG:HAND1, TFLAG:UI_HAND1_SEL, 411
CALL BATTLE_UI_PRINT_HAND_SLOT, 2, TFLAG:HAND2, TFLAG:UI_HAND2_SEL, 412
CALL BATTLE_UI_PRINT_HAND_SLOT, 3, TFLAG:HAND3, TFLAG:UI_HAND3_SEL, 413
CALL BATTLE_UI_PRINT_TEMP_SLOT, TFLAG:TEMP_CARD, TFLAG:UI_TEMP_SEL

DRAWLINE
PRINTL [410] 切換 H0 選取  [411] 切換 H1 選取  [412] 切換 H2 選取  [413] 切換 H3 選取
PRINTL [420] 切換 Temp 選取
PRINTL [450] 執行暫存槽存/取 (每回合限1次)
PRINTL [430] 確認出招
PRINTL [999] 開發者選項 (Debug)
PRINTL [0] 逃跑並返回基地

INPUT RESULT
IF RESULT == 410
    IF TFLAG:UI_HAND0_SEL == 0
        TFLAG:UI_HAND0_SEL = 1
    ELSE
        TFLAG:UI_HAND0_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 411
    IF TFLAG:UI_HAND1_SEL == 0
        TFLAG:UI_HAND1_SEL = 1
    ELSE
        TFLAG:UI_HAND1_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 412
    IF TFLAG:UI_HAND2_SEL == 0
        TFLAG:UI_HAND2_SEL = 1
    ELSE
        TFLAG:UI_HAND2_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 413
    IF TFLAG:UI_HAND3_SEL == 0
        TFLAG:UI_HAND3_SEL = 1
    ELSE
        TFLAG:UI_HAND3_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 420
    IF TFLAG:UI_TEMP_SEL == 0
        TFLAG:UI_TEMP_SEL = 1
    ELSE
        TFLAG:UI_TEMP_SEL = 0
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 450
    IF TFLAG:TEMP_USED_THIS_TURN == 1
        PRINTL 本回合已操作過暫存槽。
        GOTO BATTLE_UI_MAIN_LOOP
    ENDIF

    LOCAL:40 = 0
    LOCAL:41 = -1

    IF TFLAG:HAND0 != 0 && TFLAG:UI_HAND0_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND0
    ENDIF
    IF TFLAG:HAND1 != 0 && TFLAG:UI_HAND1_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND1
    ENDIF
    IF TFLAG:HAND2 != 0 && TFLAG:UI_HAND2_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND2
    ENDIF
    IF TFLAG:HAND3 != 0 && TFLAG:UI_HAND3_SEL == 1
        LOCAL:40 += 1
        LOCAL:41 = HAND3
    ENDIF

    IF LOCAL:40 != 1
        PRINTL 必須精確選取 1 個手牌元素才能進行暫存操作。
        GOTO BATTLE_UI_MAIN_LOOP
    ENDIF

    LOCAL:42 = TFLAG:(LOCAL:41)
    IF TFLAG:TEMP_CARD == 0
        TFLAG:TEMP_CARD = LOCAL:42
        TFLAG:(LOCAL:41) = 0
        PRINTL 已將選取手牌移入 Temp。
    ELSE
        LOCAL:43 = TFLAG:TEMP_CARD
        TFLAG:TEMP_CARD = LOCAL:42
        TFLAG:(LOCAL:41) = LOCAL:43
        PRINTL 已完成手牌與 Temp 的元素交換。
    ENDIF

    TFLAG:UI_HAND0_SEL = 0
    TFLAG:UI_HAND1_SEL = 0
    TFLAG:UI_HAND2_SEL = 0
    TFLAG:UI_HAND3_SEL = 0
    TFLAG:UI_TEMP_SEL = 0
    TFLAG:TEMP_USED_THIS_TURN = 1
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 430
    CALL BATTLE_PROCESS_ACTION
    IF RESULT == 0
        GOTO BATTLE_UI_MAIN_LOOP
    ELSEIF RESULT == 1
        RETURN 1
    ENDIF

    CALL BATTLE_ENEMY_TURN
    IF RESULT == 1
        RETURN 0
    ENDIF

    TFLAG:BATTLE_TURN += 1
    CALL BATTLE_DRAW_CARDS
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 999
    CALL DEBUG_BATTLE_MENU
    IF RESULT == 1
        CALL BATTLE_RESOLVE_VICTORY
        RETURN 1
    ENDIF
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 0
    RETURN 0
ELSE
    GOTO BATTLE_UI_MAIN_LOOP
ENDIF


@BATTLE_CALC_BOOST, ARG:0, ARG:1, ARG:2, ARG:3
; 依選取 Attribute 數量計算當回合臨時百分比 Buff
; ARG:0=火, ARG:1=水, ARG:2=風, ARG:3=土
; 對應規則：火=>PATK、水=>MATK、風=>PDEF、土=>MDEF
TFLAG:TEMP_BUFF_PATK = ARG:0 * 10
TFLAG:TEMP_BUFF_MATK = ARG:1 * 10
TFLAG:TEMP_BUFF_PDEF = ARG:2 * 10
TFLAG:TEMP_BUFF_MDEF = ARG:3 * 10
RETURN

@BATTLE_MATCH_SKILL, ARG:0, ARG:1, ARG:2, ARG:3
; 僅用 Shape 軸比對 20000~20010，可達成則回傳技能 ID，否則回傳 0
; ARG:0=物理, ARG:1=魔法, ARG:2=防禦, ARG:3=特殊
FOR LOCAL, 20000, 20010
    LOCAL:10 = SKILL_REQ_SHAPE_PHYS:LOCAL + SKILL_REQ_SHAPE_MAG:LOCAL + SKILL_REQ_SHAPE_DEF:LOCAL + SKILL_REQ_SHAPE_SPEC:LOCAL
    IF LOCAL:10 > 0
        IF ARG:0 >= SKILL_REQ_SHAPE_PHYS:LOCAL && ARG:1 >= SKILL_REQ_SHAPE_MAG:LOCAL && ARG:2 >= SKILL_REQ_SHAPE_DEF:LOCAL && ARG:3 >= SKILL_REQ_SHAPE_SPEC:LOCAL
            RETURN LOCAL
        ENDIF
    ENDIF
NEXT
RETURN 0

@BATTLE_PROCESS_ACTION
; 被選取卡牌計數：Shape(物理/魔法/防禦/特殊) + Attribute(火/水/風/土) + 總數
LOCAL:50 = 0 ; Shape 物理
LOCAL:51 = 0 ; Shape 魔法
LOCAL:52 = 0 ; Shape 防禦
LOCAL:53 = 0 ; Shape 特殊
LOCAL:54 = 0 ; 總選取數
LOCAL:55 = 0 ; Attr 火
LOCAL:56 = 0 ; Attr 水
LOCAL:57 = 0 ; Attr 風
LOCAL:58 = 0 ; Attr 土

FOR LOCAL, 0, 5
    IF LOCAL == 0
        LOCAL:20 = TFLAG:UI_HAND0_SEL
        LOCAL:21 = TFLAG:HAND0
    ELSEIF LOCAL == 1
        LOCAL:20 = TFLAG:UI_HAND1_SEL
        LOCAL:21 = TFLAG:HAND1
    ELSEIF LOCAL == 2
        LOCAL:20 = TFLAG:UI_HAND2_SEL
        LOCAL:21 = TFLAG:HAND2
    ELSEIF LOCAL == 3
        LOCAL:20 = TFLAG:UI_HAND3_SEL
        LOCAL:21 = TFLAG:HAND3
    ELSE
        LOCAL:20 = TFLAG:UI_TEMP_SEL
        LOCAL:21 = TFLAG:TEMP_CARD
    ENDIF

    IF LOCAL:20 == 1 && LOCAL:21 != 0
        LOCAL:54 += 1
        LOCAL:22 = LOCAL:21 / CARD_PACK_BASE
        LOCAL:23 = LOCAL:21 - LOCAL:22 * CARD_PACK_BASE

        SELECTCASE LOCAL:23
            CASE SHAPE_PHYS
                LOCAL:50 += 1
            CASE SHAPE_MAG
                LOCAL:51 += 1
            CASE SHAPE_DEF
                LOCAL:52 += 1
            CASE SHAPE_SPEC
                LOCAL:53 += 1
        ENDSELECT
        SELECTCASE LOCAL:22
            CASE ATTR_FIRE
                LOCAL:55 += 1
            CASE ATTR_WATER
                LOCAL:56 += 1
            CASE ATTR_WIND
                LOCAL:57 += 1
            CASE ATTR_EARTH
                LOCAL:58 += 1
        ENDSELECT
    ENDIF
NEXT

IF LOCAL:54 == 0
    PRINTW 請至少選取一張卡牌來發動攻擊！
    RETURN 0
ENDIF

CALL BATTLE_CALC_BOOST, LOCAL:55, LOCAL:56, LOCAL:57, LOCAL:58
CALL BATTLE_MATCH_SKILL, LOCAL:50, LOCAL:51, LOCAL:52, LOCAL:53
LOCAL:60 = RESULT

IF LOCAL:60 == 0
    PRINTL 【形狀連鎖】未觸發特殊技能。發動基礎攻擊！
ELSE
    PRINTFORML 【形狀連鎖】條件達成！發動技能 ID：{LOCAL:60}！
ENDIF
PRINTFORML (臨時 Buff) PATK+{TFLAG:TEMP_BUFF_PATK}％ / MATK+{TFLAG:TEMP_BUFF_MATK}％ / PDEF+{TFLAG:TEMP_BUFF_PDEF}％ / MDEF+{TFLAG:TEMP_BUFF_MDEF}％

CALL BATTLE_CALC_DAMAGE, LOCAL:60
LOCAL:70 = RESULT

; 消耗被選取卡牌
IF TFLAG:UI_HAND0_SEL == 1
    TFLAG:HAND0 = 0
ENDIF
IF TFLAG:UI_HAND1_SEL == 1
    TFLAG:HAND1 = 0
ENDIF
IF TFLAG:UI_HAND2_SEL == 1
    TFLAG:HAND2 = 0
ENDIF
IF TFLAG:UI_HAND3_SEL == 1
    TFLAG:HAND3 = 0
ENDIF
IF TFLAG:UI_TEMP_SEL == 1
    TFLAG:TEMP_CARD = 0
ENDIF

IF LOCAL:70 == 1
    RETURN 1
ENDIF

RETURN 2


@BATTLE_RESOLVE_VICTORY
LOCAL:1 = TFLAG:BATTLE_TARGET
TFLAG:BATTLE_LOOT_MONEY = 100
TFLAG:BATTLE_LOOT_MAT = 20
PRINTL 木人樁被擊破！戰鬥勝利！
IF LOCAL:1 >= 0 && LOCAL:1 < CHARANUM
    DELCHARA LOCAL:1
ENDIF
TFLAG:BATTLE_TARGET = -1
RETURN 1

@BATTLE_CALC_DAMAGE, ARG
; ARG = 技能 ID（0 代表普攻）
LOCAL:1 = TFLAG:BATTLE_TARGET
IF LOCAL:1 < 0 || LOCAL:1 >= CHARANUM
    PRINTL 目標不存在，無法進行傷害結算。
    RETURN 1
ENDIF

LOCAL:2 = BASE:MASTER:BTL_PATK
LOCAL:3 = TFLAG:TEMP_BUFF_PATK
LOCAL:4 = 0
IF ARG > 0
    LOCAL:4 = 10 + (ARG - 20000) * 5
ENDIF
LOCAL:5 = BASE:(LOCAL:1):BTL_PDEF
LOCAL:6 = LOCAL:2 * (100 + LOCAL:3) / 100
LOCAL:7 = LOCAL:6 + LOCAL:4 - LOCAL:5
IF LOCAL:7 < 0
    LOCAL:7 = 0
ENDIF

BASE:(LOCAL:1):BTL_HP -= LOCAL:7
IF BASE:(LOCAL:1):BTL_HP < 0
    BASE:(LOCAL:1):BTL_HP = 0
ENDIF

PRINTFORML 對木人樁造成了 {LOCAL:7} 點傷害！(剩餘 HP: {BASE:(LOCAL:1):BTL_HP}/{BASE:(LOCAL:1):BTL_MAXHP})

IF BASE:(LOCAL:1):BTL_HP <= 0
    CALL BATTLE_RESOLVE_VICTORY
    RETURN RESULT
ENDIF
RETURN 0


@BATTLE_ENEMY_TURN
LOCAL:5 = TFLAG:BATTLE_TARGET
IF LOCAL:5 < 0 || LOCAL:5 >= CHARANUM
    RETURN 1
ENDIF
IF BASE:(LOCAL:5):BTL_HP <= 0
    RETURN 1
ENDIF

LOCAL:1 = 0
FOR LOCAL, 0, 4
    LOCAL:2 = PARTY_MEMBERS:LOCAL
    IF LOCAL:2 != -1 && BASE:(LOCAL:2):BTL_HP > 0
        LOCAL:(10 + LOCAL:1) = LOCAL:2
        LOCAL:1 += 1
    ENDIF
NEXT

IF LOCAL:1 <= 0
    RETURN 1
ENDIF

LOCAL:3 = RAND:(LOCAL:1)
LOCAL:2 = LOCAL:(10 + LOCAL:3)
DRAWLINE
PRINTFORML 【敵方回合】 %CALLNAME:(LOCAL:5)% 發動了攻擊！
LOCAL:4 = BASE:(LOCAL:5):BTL_PATK - BASE:(LOCAL:2):BTL_PDEF
IF LOCAL:4 < 0
    LOCAL:4 = 0
ENDIF

BASE:(LOCAL:2):BTL_HP -= LOCAL:4
IF BASE:(LOCAL:2):BTL_HP < 0
    BASE:(LOCAL:2):BTL_HP = 0
ENDIF

PRINTFORML 對 [%CALLNAME:(LOCAL:2)%] 造成了 {LOCAL:4} 點傷害！ (剩餘 HP: {BASE:(LOCAL:2):BTL_HP}/{BASE:(LOCAL:2):BTL_MAXHP})

IF BASE:MASTER:BTL_HP <= 0
    PRINTL 主角倒下了，戰鬥敗北。
    DELCHARA LOCAL:5
    TFLAG:BATTLE_TARGET = -1
    RETURN 1
ENDIF
RETURN 0
