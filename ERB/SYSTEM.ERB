@EVENTFIRST
; ===== 系統啟動入口 =====
; 僅在新遊戲啟動時初始化，避免讀檔時覆蓋存檔數值
IF FLAG:SYS_INITIALIZED == 0
    CALL INIT_BASE_STATE
ENDIF
CALL TITLE_SCREEN
RETURN

@INIT_BASE_STATE
; ===== 全域初始化 =====
FLAG:SYS_INITIALIZED = 1
FLAG:BASE_DAY = 1
FLAG:DAY_PHASE = 1

; Core Loop 初始資源（可依平衡再調整）
FLAG:RES_MONEY = 1000
FLAG:RES_MATERIAL = 80
FLAG:RES_SUPPLY = 60

; 基地設施初始等級
FLAG:BASE_FAC_LV_TRAIN = 1
FLAG:BASE_FAC_LV_WORK = 1
FLAG:BASE_FAC_LV_LOUNGE = 1
FLAG:BASE_FAC_LV_ROOM = 1

; NPC 測試狀態
FLAG:NPC_JOIN_1 = 0
FLAG:NPC_JOIN_2 = 0
FLAG:NPC_RESIDENT_1 = 0
FLAG:NPC_RESIDENT_2 = 0
FLAG:NPC_ROOM_SLOT_1 = 9999
FLAG:NPC_ROOM_SLOT_2 = 9999
CALL INIT_ROOM_OWNER
CALL INIT_CARD_DATA

; 當日流程保護旗標
TFLAG:MORNING_DONE = 0
TFLAG:RETURN_PHASE = 0
RETURN

@INIT_ROOM_OWNER
FOR LOCAL, 0, ROOM_OWNER_MAX - 1
    ROOM_OWNER:LOCAL = -1
NEXT
RETURN

@INIT_CARD_DATA
; ===== 卡牌資料初始化（手動註冊） =====
; 先清空本期使用區間，避免重複初始化時殘留舊值
FOR LOCAL, 10000, 10005
    CARD_ENERGY_COST:LOCAL = 0
    CARD_BASE_POWER:LOCAL = 0
    CARD_BASE_ACC:LOCAL = 0
NEXT

; 10001 斬擊
CARD_ENERGY_COST:10001 = 1
CARD_BASE_POWER:10001 = 10
CARD_BASE_ACC:10001 = 80

; 10002 重擊
CARD_ENERGY_COST:10002 = 2
CARD_BASE_POWER:10002 = 18
CARD_BASE_ACC:10002 = 65

; 10003 格擋
CARD_ENERGY_COST:10003 = 1
CARD_BASE_POWER:10003 = 0
CARD_BASE_ACC:10003 = 100

; 10004 破甲
CARD_ENERGY_COST:10004 = 2
CARD_BASE_POWER:10004 = 12
CARD_BASE_ACC:10004 = 75

; 10005 專注
CARD_ENERGY_COST:10005 = 1
CARD_BASE_POWER:10005 = 0
CARD_BASE_ACC:10005 = 100
RETURN

@TITLE_SCREEN
$TITLE_TOP
DRAWLINE
PRINTL  ERA ISEKAI
PRINTL  養成 × 經營 × 抽牌戰鬥
DRAWLINE
PRINTL  [1] 開始遊戲
PRINTL  [2] 測試：加入隨機 NPC
PRINTL  [0] 結束
PRINTL
PRINTFORML 請輸入選項：
INPUT RESULT

IF RESULT == 1
    CALL GAME_LOOP
    RETURN
ELSEIF RESULT == 2
    CALL TEST_ADD_RANDOM_NPC
    GOTO TITLE_TOP
ELSEIF RESULT == 0
    QUIT
ELSE
    PRINTL 請輸入 1、2 或 0。
    GOTO TITLE_TOP
ENDIF

@GAME_LOOP
; ===== 每日主循環入口 =====
WHILE 1
    IF FLAG:DAY_PHASE == 1
        CALL PHASE_MORNING
    ELSEIF FLAG:DAY_PHASE == 2
        CALL PHASE_DAY
    ELSEIF FLAG:DAY_PHASE == 3
        CALL PHASE_NIGHT
    ELSE
        CALL SYS_RECOVER
    ENDIF
WEND
RETURN

@PHASE_MORNING
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／晨間】
IF TFLAG:MORNING_DONE == 0
    LOCAL:20 = 0
    LOCAL:21 = 0
    LOCAL:22 = 0
    LOCAL:23 = 0
    LOCAL:24 = 0
    LOCAL:25 = 0

    ; 設施產出：工坊提供金錢/材料，訓練室與休息室提供少量補給回補
    LOCAL:20 = 40 + FLAG:BASE_FAC_LV_WORK * 60
    LOCAL:21 = 8 + FLAG:BASE_FAC_LV_WORK * 6
    LOCAL:22 = FLAG:BASE_FAC_LV_TRAIN * 2 + FLAG:BASE_FAC_LV_LOUNGE * 3

    FLAG:RES_MONEY += LOCAL:20
    FLAG:RES_MATERIAL += LOCAL:21
    FLAG:RES_SUPPLY += LOCAL:22

    ; 維護費結算：優先扣補給，不足再扣金錢
    LOCAL:10 = FLAG:BASE_FAC_LV_ROOM
    IF LOCAL:10 < 0
        LOCAL:10 = 0
    ELSEIF LOCAL:10 > ROOM_OWNER_MAX
        LOCAL:10 = ROOM_OWNER_MAX
    ENDIF

    FOR LOCAL, 0, LOCAL:10 - 1
        IF ROOM_OWNER:LOCAL == -1
            CONTINUE
        ENDIF

        LOCAL:1 = ROOM_OWNER:LOCAL
        LOCAL:2 = 3
        LOCAL:3 = CFLAG:(LOCAL:1):CF_MAINT_COST_MOD
        LOCAL:2 = LOCAL:2 + LOCAL:2 * LOCAL:3 / 100
        IF LOCAL:2 < 1
            LOCAL:2 = 1
        ENDIF

        LOCAL:4 = LOCAL:2
        IF FLAG:RES_SUPPLY >= LOCAL:4
            FLAG:RES_SUPPLY -= LOCAL:4
            LOCAL:23 += LOCAL:4
            CONTINUE
        ENDIF

        LOCAL:5 = LOCAL:4 - FLAG:RES_SUPPLY
        LOCAL:23 += FLAG:RES_SUPPLY
        FLAG:RES_SUPPLY = 0

        LOCAL:6 = LOCAL:5 * 12
        IF FLAG:RES_MONEY >= LOCAL:6
            FLAG:RES_MONEY -= LOCAL:6
            LOCAL:24 += LOCAL:6
        ELSE
            LOCAL:24 += FLAG:RES_MONEY
            FLAG:RES_MONEY = 0
            LOCAL:25 += 1
        ENDIF
    NEXT

    ; 防呆：資源不可低於 0
    IF FLAG:RES_MONEY < 0
        FLAG:RES_MONEY = 0
    ENDIF
    IF FLAG:RES_MATERIAL < 0
        FLAG:RES_MATERIAL = 0
    ENDIF
    IF FLAG:RES_SUPPLY < 0
        FLAG:RES_SUPPLY = 0
    ENDIF

    PRINTL --- 晨報 ---
    PRINTFORML 設施收益：金錢 +{LOCAL:20} / 材料 +{LOCAL:21} / 補給 +{LOCAL:22}
    PRINTFORML 維護扣減：補給 -{LOCAL:23} / 金錢 -{LOCAL:24}
    IF LOCAL:25 > 0
        PRINTFORML [警告] 有 {LOCAL:25} 名入住 NPC 維護費未足額支付！
    ENDIF
    PRINTFORML 當前資源：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL} / 補給 {FLAG:RES_SUPPLY}
    TFLAG:MORNING_DONE = 1
ENDIF
PRINTL [1] 開始日間
INPUT RESULT
IF RESULT == 1
    FLAG:DAY_PHASE = 2
ENDIF
RETURN

@PHASE_DAY
$PHASE_DAY_MENU
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／日間】
PRINTL [1] 基地管理
PRINTL [2] 進入戰鬥（暫定）
PRINTL [9] 結束日間
INPUT RESULT

IF RESULT == 1
    CALL BASE_MENU
    GOTO PHASE_DAY_MENU
ELSEIF RESULT == 2
    TFLAG:RETURN_PHASE = 2
    CALL BATTLE_ENTER
    GOTO PHASE_DAY_MENU
ELSEIF RESULT == 9
    FLAG:DAY_PHASE = 3
ENDIF
RETURN

@PHASE_NIGHT
$PHASE_NIGHT_MENU
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／晚間】
PRINTL [1] 晚間行動（暫定）
PRINTL [2] 進入戰鬥（暫定）
PRINTL [9] 就寢
INPUT RESULT

IF RESULT == 1
    PRINTL 你完成了晚間整備。
    GOTO PHASE_NIGHT_MENU
ELSEIF RESULT == 2
    TFLAG:RETURN_PHASE = 3
    CALL BATTLE_ENTER
    GOTO PHASE_NIGHT_MENU
ELSEIF RESULT == 9
    ; 日末數值結算：入住 NPC 疲勞自然下降，過勞會降低心情
    LOCAL:10 = FLAG:BASE_FAC_LV_ROOM
    IF LOCAL:10 < 0
        LOCAL:10 = 0
    ELSEIF LOCAL:10 > ROOM_OWNER_MAX
        LOCAL:10 = ROOM_OWNER_MAX
    ENDIF

    FOR LOCAL, 0, LOCAL:10 - 1
        IF ROOM_OWNER:LOCAL == -1
            CONTINUE
        ENDIF

        LOCAL:1 = ROOM_OWNER:LOCAL
        LOCAL:2 = CFLAG:(LOCAL:1):CF_FATIGUE
        LOCAL:3 = 8 + FLAG:BASE_FAC_LV_LOUNGE * 2
        LOCAL:2 -= LOCAL:3
        IF LOCAL:2 < 0
            LOCAL:2 = 0
        ENDIF
        CFLAG:(LOCAL:1):CF_FATIGUE = LOCAL:2

        IF LOCAL:2 >= 80
            CFLAG:(LOCAL:1):CF_MOOD -= 8
        ELSEIF LOCAL:2 >= 60
            CFLAG:(LOCAL:1):CF_MOOD -= 3
        ELSE
            CFLAG:(LOCAL:1):CF_MOOD += 1
        ENDIF

        IF CFLAG:(LOCAL:1):CF_MOOD < 0
            CFLAG:(LOCAL:1):CF_MOOD = 0
        ELSEIF CFLAG:(LOCAL:1):CF_MOOD > 100
            CFLAG:(LOCAL:1):CF_MOOD = 100
        ENDIF
    NEXT

    CALL TRIGGER_NIGHT_EVENT

    ; 一天結束，推進到隔日晨間
    FLAG:BASE_DAY += 1
    FLAG:DAY_PHASE = 1
    TFLAG:MORNING_DONE = 0
ENDIF
RETURN

@BATTLE_ENTER
BASE:MASTER:BTL_MAXHP = 100
BASE:MASTER:BTL_HP = 100
BASE:MASTER:BTL_MAXEN = 10
BASE:MASTER:BTL_EN = 10

TFLAG:BATTLE_TURN = 1
TFLAG:HAND0 = 0
TFLAG:HAND1 = 0
TFLAG:HAND2 = 0
TFLAG:HAND3 = 0
TFLAG:TEMP_CARD = 0

CALL BATTLE_DRAW_CARDS
CALL BATTLE_UI_MAIN
RETURN

@BATTLE_DRAW_CARDS
FOR LOCAL, HAND0, HAND3 + 1
    IF TFLAG:LOCAL == 0
        TFLAG:LOCAL = 10001 + RAND:5
    ENDIF
NEXT

TFLAG:TEMP_USED_THIS_TURN = 0
RETURN

@BATTLE_UI_MAIN
$BATTLE_UI_MAIN_LOOP
DRAWLINE
PRINTFORML 【戰鬥】Turn {TFLAG:BATTLE_TURN}
PRINTFORML HP {BASE:MASTER:BTL_HP}/{BASE:MASTER:BTL_MAXHP} | EN {BASE:MASTER:BTL_EN}/{BASE:MASTER:BTL_MAXEN} | TempUsed {TFLAG:TEMP_USED_THIS_TURN}
DRAWLINE

PRINTL (技能映射提示區預留位置)
DRAWLINE

LOCAL:20 = TFLAG:HAND0
LOCAL:21 = TFLAG:HAND1
LOCAL:22 = TFLAG:HAND2
LOCAL:23 = TFLAG:HAND3
LOCAL:24 = TFLAG:TEMP_CARD

PRINTFORML [H0] %ITEMNAME:(LOCAL:20)%
PRINTFORML [H1] %ITEMNAME:(LOCAL:21)%
PRINTFORML [H2] %ITEMNAME:(LOCAL:22)%
PRINTFORML [H3] %ITEMNAME:(LOCAL:23)%

IF LOCAL:24 == 0
    PRINTL [T] Temp: Empty
ELSE
    PRINTFORML [T] Temp: %ITEMNAME:(LOCAL:24)%
ENDIF

DRAWLINE
PRINTL [410] 選 H0  [411] 選 H1  [412] 選 H2  [413] 選 H3
PRINTL [420] Temp 存牌  [421] Temp 取牌
PRINTL [430] 確認出招
PRINTL [0] 逃跑並返回基地

INPUT RESULT
IF RESULT == 430
    TFLAG:BATTLE_TURN += 1
    CALL BATTLE_DRAW_CARDS
    GOTO BATTLE_UI_MAIN_LOOP
ELSEIF RESULT == 0
    RETURN
ELSE
    GOTO BATTLE_UI_MAIN_LOOP
ENDIF


@TEST_ADD_RANDOM_NPC
IF FLAG:NPC_JOIN_1 == 1 && FLAG:NPC_JOIN_2 == 1
    PRINTL 兩位測試 NPC 都已加入。
    RETURN
ENDIF

IF FLAG:NPC_JOIN_1 == 0 && FLAG:NPC_JOIN_2 == 0
    IF RAND:2 == 0
        FLAG:NPC_JOIN_1 = 1
        PRINTL 測試NPC_A 已加入基地。
    ELSE
        FLAG:NPC_JOIN_2 = 1
        PRINTL 測試NPC_B 已加入基地。
    ENDIF
    RETURN
ENDIF

IF FLAG:NPC_JOIN_1 == 0
    FLAG:NPC_JOIN_1 = 1
    PRINTL 測試NPC_A 已加入基地。
    RETURN
ENDIF

FLAG:NPC_JOIN_2 = 1
PRINTL 測試NPC_B 已加入基地。
RETURN

@SYS_RECOVER
PRINTL [警告] 偵測到非法 DAY_PHASE，已重置為晨間。
FLAG:DAY_PHASE = 1
RETURN


@TRIGGER_NIGHT_EVENT
; 晚間隨機事件擴充入口（預留）
RETURN
