@EVENTFIRST
; ===== 系統啟動入口 =====
; 僅在新遊戲啟動時初始化，避免讀檔時覆蓋存檔數值
IF FLAG:SYS_INITIALIZED == 0
    CALL INIT_BASE_STATE
ENDIF
CALL TITLE_SCREEN
RETURN

@INIT_BASE_STATE
; ===== 全域初始化 =====
FLAG:SYS_INITIALIZED = 1
FLAG:BASE_DAY = 1
FLAG:DAY_PHASE = 1

; Core Loop 初始資源（可依平衡再調整）
FLAG:RES_MONEY = 1000
FLAG:RES_MATERIAL = 80
FLAG:RES_SUPPLY = 60

; 基地設施初始等級
FLAG:BASE_FAC_LV_TRAIN = 1
FLAG:BASE_FAC_LV_WORK = 1
FLAG:BASE_FAC_LV_LOUNGE = 1
FLAG:BASE_FAC_LV_ROOM = 1

; NPC 測試狀態
FLAG:NPC_JOIN_1 = 0
FLAG:NPC_JOIN_2 = 0
FLAG:NPC_RESIDENT_1 = 0
FLAG:NPC_RESIDENT_2 = 0
FLAG:NPC_ROOM_SLOT_1 = 9999
FLAG:NPC_ROOM_SLOT_2 = 9999
FOR LOCAL, 0, 99
    ROOM_OWNER:LOCAL = -1
NEXT

; 當日流程保護旗標
TFLAG:MORNING_DONE = 0
TFLAG:RETURN_PHASE = 0
RETURN

@TITLE_SCREEN
$TITLE_TOP
DRAWLINE
PRINTL  ERA ISEKAI
PRINTL  養成 × 經營 × 抽牌戰鬥
DRAWLINE
PRINTL  [1] 開始遊戲
PRINTL  [2] 測試：加入隨機 NPC
PRINTL  [0] 結束
PRINTL
PRINTFORML 請輸入選項：
INPUT RESULT

IF RESULT == 1
    CALL GAME_LOOP
    RETURN
ELSEIF RESULT == 2
    CALL TEST_ADD_RANDOM_NPC
    GOTO TITLE_TOP
ELSEIF RESULT == 0
    QUIT
ELSE
    PRINTL 請輸入 1、2 或 0。
    GOTO TITLE_TOP
ENDIF

@GAME_LOOP
; ===== 每日主循環入口 =====
WHILE 1
    IF FLAG:DAY_PHASE == 1
        CALL PHASE_MORNING
    ELSEIF FLAG:DAY_PHASE == 2
        CALL PHASE_DAY
    ELSEIF FLAG:DAY_PHASE == 3
        CALL PHASE_NIGHT
    ELSE
        CALL SYS_RECOVER
    ENDIF
WEND
RETURN

@PHASE_MORNING
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／晨間】
IF TFLAG:MORNING_DONE == 0
    ; 晨間一次性結算入口（目前先做基礎示意）
    TFLAG:MORNING_DONE = 1
    PRINTL 設施產出與維護結算完成。
    PRINTFORML 資源：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL} / 補給 {FLAG:RES_SUPPLY}
ENDIF
PRINTL [1] 開始日間
INPUT RESULT
IF RESULT == 1
    FLAG:DAY_PHASE = 2
ENDIF
RETURN

@PHASE_DAY
$PHASE_DAY_MENU
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／日間】
PRINTL [1] 基地管理
PRINTL [2] 進入戰鬥（暫定）
PRINTL [9] 結束日間
INPUT RESULT

IF RESULT == 1
    CALL BASE_MENU
    GOTO PHASE_DAY_MENU
ELSEIF RESULT == 2
    TFLAG:RETURN_PHASE = 2
    CALL BATTLE_ENTER
    GOTO PHASE_DAY_MENU
ELSEIF RESULT == 9
    FLAG:DAY_PHASE = 3
ENDIF
RETURN

@PHASE_NIGHT
$PHASE_NIGHT_MENU
DRAWLINE
PRINTFORML 【第{FLAG:BASE_DAY}天／晚間】
PRINTL [1] 晚間行動（暫定）
PRINTL [2] 進入戰鬥（暫定）
PRINTL [9] 就寢
INPUT RESULT

IF RESULT == 1
    PRINTL 你完成了晚間整備。
    GOTO PHASE_NIGHT_MENU
ELSEIF RESULT == 2
    TFLAG:RETURN_PHASE = 3
    CALL BATTLE_ENTER
    GOTO PHASE_NIGHT_MENU
ELSEIF RESULT == 9
    ; 一天結束，推進到隔日晨間
    FLAG:BASE_DAY += 1
    FLAG:DAY_PHASE = 1
    TFLAG:MORNING_DONE = 0
ENDIF
RETURN

@BATTLE_ENTER
DRAWLINE
PRINTL 【戰鬥階段（暫定）】
PRINTL 戰鬥結束，返回原階段。
RETURN


@TEST_ADD_RANDOM_NPC
IF FLAG:NPC_JOIN_1 == 1 && FLAG:NPC_JOIN_2 == 1
    PRINTL 兩位測試 NPC 都已加入。
    RETURN
ENDIF

IF FLAG:NPC_JOIN_1 == 0 && FLAG:NPC_JOIN_2 == 0
    IF RAND:2 == 0
        FLAG:NPC_JOIN_1 = 1
        PRINTL 測試NPC_A 已加入基地。
    ELSE
        FLAG:NPC_JOIN_2 = 1
        PRINTL 測試NPC_B 已加入基地。
    ENDIF
    RETURN
ENDIF

IF FLAG:NPC_JOIN_1 == 0
    FLAG:NPC_JOIN_1 = 1
    PRINTL 測試NPC_A 已加入基地。
    RETURN
ENDIF

FLAG:NPC_JOIN_2 = 1
PRINTL 測試NPC_B 已加入基地。
RETURN

@SYS_RECOVER
PRINTL [警告] 偵測到非法 DAY_PHASE，已重置為晨間。
FLAG:DAY_PHASE = 1
RETURN
