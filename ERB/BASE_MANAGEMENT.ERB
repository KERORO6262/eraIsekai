@BASE_MENU
$BASE_MENU_TOP
DRAWLINE
PRINTL 【基地管理】
PRINTFORML 資源：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL} / 補給 {FLAG:RES_SUPPLY}
DRAWLINE
PRINTL [1] 訓練室
PRINTL [2] 工坊
PRINTL [3] 休息室
PRINTL [4] 房間管理
PRINTL [9] 返回日間選單
INPUT RESULT

IF RESULT == 1
    PRINTL 你進入了訓練室（暫定）。
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 2
    PRINTL 你進入了工坊（暫定）。
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 3
    PRINTL 你進入了休息室（暫定）。
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 4
    PRINTL 你進入了房間管理（暫定）。
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 9
    RETURN
ENDIF

PRINTL 請輸入 1/2/3/4/9。
GOTO BASE_MENU_TOP
