@BASE_MENU
$BASE_MENU_TOP
DRAWLINE
PRINTL 【基地管理】
PRINTFORML 資源：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL} / 補給 {FLAG:RES_SUPPLY}
DRAWLINE
PRINTL [1] 訓練室
PRINTL [2] 工坊
PRINTL [3] 休息室
PRINTL [4] 房間管理
PRINTL [0] 測試：獲得金錢 +500
PRINTL [9] 返回日間選單
INPUT RESULT

IF RESULT == 1
    CALL FACILITY_TRAIN
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 2
    CALL FACILITY_WORK
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 3
    CALL FACILITY_LOUNGE
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 4
    CALL FACILITY_ROOM
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 0
    FLAG:RES_MONEY += 500
    PRINTL 已獲得測試金錢 +500。
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 9
    RETURN
ENDIF

PRINTL 請輸入 0/1/2/3/4/9。
GOTO BASE_MENU_TOP

@FACILITY_TRAIN
CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_TRAIN, "訓練室"
IF RESULT == 1
    FLAG:BASE_FAC_LV_TRAIN += 1
ENDIF
RETURN

@FACILITY_WORK
CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_WORK, "工坊"
IF RESULT == 1
    FLAG:BASE_FAC_LV_WORK += 1
ENDIF
RETURN

@FACILITY_LOUNGE
CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_LOUNGE, "休息室"
IF RESULT == 1
    FLAG:BASE_FAC_LV_LOUNGE += 1
ENDIF
RETURN

@FACILITY_ROOM
CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_ROOM, "房間管理"
IF RESULT == 1
    FLAG:BASE_FAC_LV_ROOM += 1
ENDIF
RETURN

@FACILITY_UPGRADE_MENU, ARG, ARGS
$FACILITY_MENU_LOOP
LOCAL = ARG
LOCAL:1 = 300 + LOCAL * 250 + LOCAL * LOCAL * 120
LOCAL:2 = 80 + LOCAL * 60 + LOCAL * LOCAL * 20

DRAWLINE
PRINTFORML 【%ARGS%】
PRINTFORML 目前等級：Lv.{LOCAL}
PRINTFORML 升級消耗：金錢 {LOCAL:1} / 材料 {LOCAL:2}
PRINTFORML 持有資源：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL}
PRINTL [1] 升級
PRINTL [9] 返回基地選單
INPUT RESULT

IF RESULT == 9
    RESULT = 0
    RETURN
ENDIF
IF RESULT != 1
    PRINTL 請輸入 1 或 9。
    GOTO FACILITY_MENU_LOOP
ENDIF

IF FLAG:RES_MONEY < LOCAL:1
    PRINTL 金錢不足，無法升級。
    RESULT = 0
    RETURN
ENDIF
IF FLAG:RES_MATERIAL < LOCAL:2
    PRINTL 材料不足，無法升級。
    RESULT = 0
    RETURN
ENDIF

FLAG:RES_MONEY -= LOCAL:1
FLAG:RES_MATERIAL -= LOCAL:2
PRINTFORML %ARGS% 升級成功！
RESULT = 1
RETURN
