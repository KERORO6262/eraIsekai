@BASE_MENU
$BASE_MENU_TOP
DRAWLINE
PRINTL 【基地管理】
PRINTFORML 資源：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL} / 補給 {FLAG:RES_SUPPLY}
DRAWLINE
PRINTL [1] 訓練室
PRINTL [2] 工坊
PRINTL [3] 休息室
PRINTL [4] 房間管理
PRINTL [0] 測試：獲得金錢 +500 / 材料 +50
PRINTL [9] 返回日間選單
INPUT RESULT

IF RESULT == 1
    CALL FACILITY_TRAIN
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 2
    CALL FACILITY_WORK
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 3
    CALL FACILITY_LOUNGE
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 4
    CALL FACILITY_ROOM
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 0
    FLAG:RES_MONEY += 500
    FLAG:RES_MATERIAL += 50
    PRINTL 已獲得測試資源：金錢 +500 / 材料 +50。
    GOTO BASE_MENU_TOP
ENDIF
IF RESULT == 9
    RETURN
ENDIF

PRINTL 請輸入 0/1/2/3/4/9。
GOTO BASE_MENU_TOP

@FACILITY_TRAIN
CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_TRAIN, "訓練室"
IF RESULT == 1
    FLAG:BASE_FAC_LV_TRAIN += 1
ENDIF
RETURN

@FACILITY_WORK
CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_WORK, "工坊"
IF RESULT == 1
    FLAG:BASE_FAC_LV_WORK += 1
ENDIF
RETURN

@FACILITY_LOUNGE
CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_LOUNGE, "休息室"
IF RESULT == 1
    FLAG:BASE_FAC_LV_LOUNGE += 1
ENDIF
RETURN

@FACILITY_ROOM
$ROOM_MENU_TOP
LOCAL:90 = FLAG:BASE_FAC_LV_ROOM * 2
DRAWLINE
PRINTFORML 【房間管理 Lv.{FLAG:BASE_FAC_LV_ROOM}】
PRINTFORML 可用槽位：{LOCAL:90}
PRINTL
FOR LOCAL, 0, LOCAL:90 - 1
    IF ROOM_OWNER:LOCAL == -1
        PRINTFORML [{LOCAL + 1}] 狀態：[空]
    ELSE
        LOCAL:1 = ROOM_OWNER:LOCAL
        PRINTFORML [{LOCAL + 1}] 狀態：[%NAME:LOCAL:1%]
    ENDIF
NEXT
PRINTL
PRINTL [1~槽位上限] 分配/撤離 NPC
PRINTL [99] 升級房間設施
PRINTL [9] 返回基地選單
INPUT RESULT

IF RESULT == 9
    RETURN
ENDIF
IF RESULT == 99
    CALL FACILITY_UPGRADE_MENU, FLAG:BASE_FAC_LV_ROOM, "房間管理"
    IF RESULT == 1
        FLAG:BASE_FAC_LV_ROOM += 1
    ENDIF
    GOTO ROOM_MENU_TOP
ENDIF
IF RESULT < 1 || RESULT > LOCAL:90
    PRINTL 無效的槽位編號。
    GOTO ROOM_MENU_TOP
ENDIF

LOCAL = RESULT - 1
IF ROOM_OWNER:LOCAL == -1
    CALL ROOM_ASSIGN_SELECT, LOCAL
ELSE
    CALL ROOM_EVICT_CONFIRM, LOCAL
ENDIF
GOTO ROOM_MENU_TOP

@ROOM_ASSIGN_SELECT, ARG
$ROOM_ASSIGN_TOP
LOCAL = ARG
LOCAL:10 = 0
PRINTFORML 【槽位 {LOCAL + 1}：入住分配】

FOR LOCAL:1, 0, CHARANUM - 1
    IF CFLAG:LOCAL:1:IS_RESIDENT == 0
        LOCAL:100:LOCAL:10 = LOCAL:1
        PRINTFORML [{LOCAL:10 + 1}] %NAME:LOCAL:1%
        LOCAL:10 += 1
    ENDIF
NEXT

IF LOCAL:10 == 0
    PRINTL 目前沒有可入住的 NPC。
    PRINTL [9] 返回
    INPUT RESULT
    RETURN
ENDIF

PRINTL [9] 取消
INPUT RESULT
IF RESULT == 9
    RETURN
ENDIF
IF RESULT < 1 || RESULT > LOCAL:10
    PRINTL 請輸入有效 NPC 編號。
    GOTO ROOM_ASSIGN_TOP
ENDIF

LOCAL:3 = RESULT - 1
LOCAL:2 = LOCAL:100:LOCAL:3
ROOM_OWNER:LOCAL = LOCAL:2
CFLAG:LOCAL:2:IS_RESIDENT = 1
CFLAG:LOCAL:2:ROOM_SLOT = LOCAL
PRINTFORML 已安排 [%NAME:LOCAL:2%] 入住槽位 {LOCAL + 1}。
RETURN

@ROOM_EVICT_CONFIRM, ARG
LOCAL = ARG
LOCAL:1 = ROOM_OWNER:LOCAL
PRINTFORML 【槽位 {LOCAL + 1}：%NAME:LOCAL:1%】
PRINTL 是否撤離該 NPC？
PRINTL [1] 確認撤離
PRINTL [9] 取消
INPUT RESULT
IF RESULT != 1
    RETURN
ENDIF

ROOM_OWNER:LOCAL = -1
CFLAG:LOCAL:1:IS_RESIDENT = 0
CFLAG:LOCAL:1:ROOM_SLOT = 9999
PRINTFORML 已將 [%NAME:LOCAL:1%] 撤離。
RETURN

@FACILITY_UPGRADE_MENU, ARG, ARGS
$FACILITY_MENU_LOOP
LOCAL = ARG
LOCAL:1 = 300 + LOCAL * 250 + LOCAL * LOCAL * 120
LOCAL:2 = 80 + LOCAL * 60 + LOCAL * LOCAL * 20

DRAWLINE
PRINTFORML 【%ARGS%】
PRINTFORML 目前等級：Lv.{LOCAL}
PRINTFORML 升級消耗：金錢 {LOCAL:1} / 材料 {LOCAL:2}
PRINTFORML 持有資源：金錢 {FLAG:RES_MONEY} / 材料 {FLAG:RES_MATERIAL}
PRINTL [1] 升級
PRINTL [9] 返回基地選單
INPUT RESULT

IF RESULT == 9
    RESULT = 0
    RETURN
ENDIF
IF RESULT != 1
    PRINTL 請輸入 1 或 9。
    GOTO FACILITY_MENU_LOOP
ENDIF

IF FLAG:RES_MONEY < LOCAL:1
    PRINTL 金錢不足，無法升級。
    RESULT = 0
    RETURN
ENDIF
IF FLAG:RES_MATERIAL < LOCAL:2
    PRINTL 材料不足，無法升級。
    RESULT = 0
    RETURN
ENDIF

FLAG:RES_MONEY -= LOCAL:1
FLAG:RES_MATERIAL -= LOCAL:2
PRINTFORML %ARGS% 升級成功！
RESULT = 1
RETURN
